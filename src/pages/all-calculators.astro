<script>
  function sortCalculatorsAlphabetically() {
    const grid = document.getElementById('dir-calculators-grid');
    if (!grid) return;

    const cards = Array.from(grid.querySelectorAll('.calc-card-item'));
    cards.sort((a, b) => {
      const titleA = a.querySelector('.calc-card-title')?.textContent?.trim().toLowerCase() || '';
      const titleB = b.querySelector('.calc-card-title')?.textContent?.trim().toLowerCase() || '';
      return titleA.localeCompare(titleB);
    });

    cards.forEach((card) => grid.appendChild(card));
  }

  function initDirectorySearch() {
    // Automatically sort all calculators alphabetically A to Z upon page render
    sortCalculatorsAlphabetically();

    const searchInput = document.getElementById('dir-search-input') as HTMLInputElement;
    const cards = document.querySelectorAll('.calc-card-item');
    const emptyState = document.getElementById('dir-empty-state');

    if (!searchInput || cards.length === 0) return;

    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;

      cards.forEach((card) => {
        const keywords = card.getAttribute('data-keywords') || '';
        if (query === '' || keywords.includes(query)) {
          (card as HTMLElement).classList.remove('hidden');
          visibleCount++;
        } else {
          (card as HTMLElement).classList.add('hidden');
        }
      });

      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
      } else {
        emptyState?.classList.add('hidden');
      }
    });
  }

  // Bind events
  document.addEventListener('DOMContentLoaded', initDirectorySearch);
  document.addEventListener('astro:after-swap', initDirectorySearch);
</script>

<style>

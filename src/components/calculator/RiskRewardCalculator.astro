---
import CalculatorLayout from './CalculatorLayout.astro';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
---

<CalculatorLayout
  title="Risk Reward Calculator"
  description="Calculate the risk-reward ratio, recommended position size in shares or units, breakeven win rate, and expected value (expectancy) for your trades."
  category="Savings"
>
  <!-- Inputs Section -->
  <div slot="inputs" class="calc-inputs-wrapper" id="risk-reward-calculator">
    
    <!-- Account Currency Selection -->
    <div class="input-group" id="group-currency">
      <div class="input-label-row">
        <label for="rr-currency-select">Currency</label>
        <select id="rr-currency-select" class="currency-select" aria-label="Select Currency">
          <option value="USD" selected>USD ($) - US Dollar</option>
          <option value="EUR">EUR (€) - Euro</option>
          <option value="GBP">GBP (£) - British Pound</option>
          <option value="INR">INR (₹) - Indian Rupee</option>
          <option value="JPY">JPY (¥) - Japanese Yen</option>
          <option value="AUD">AUD (A$) - Australian Dollar</option>
          <option value="CAD">CAD (C$) - Canadian Dollar</option>
          <option value="SGD">SGD (S$) - Singapore Dollar</option>
          <option value="CHF">CHF (CHF) - Swiss Franc</option>
        </select>
      </div>
    </div>

    <!-- Account Balance -->
    <div class="input-group" id="group-balance">
      <div class="input-label-row">
        <label for="rr-balance-input">Account Balance</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="rr-balance-input" min="10" step="100" value="10000" aria-label="Account Balance" />
        </div>
      </div>
      <input type="range" id="rr-balance-slider" min="100" max="100000" step="100" value="10000" class="slider-range" aria-label="Account Balance Slider" />
    </div>

    <!-- Risk Percentage (%) -->
    <div class="input-group" id="group-risk-pct">
      <div class="input-label-row">
        <label for="rr-risk-input">Risk Percentage (%)</label>
        <div class="input-symbol-wrapper percent-wrapper">
          <input type="number" id="rr-risk-input" min="0.1" max="20" step="0.1" value="1.5" aria-label="Risk Percentage" />
          <span class="percent-symbol">%</span>
        </div>
      </div>
      <input type="range" id="rr-risk-slider" min="0.1" max="10" step="0.1" value="1.5" class="slider-range" aria-label="Risk Percentage Slider" />
    </div>

    <!-- Entry Price -->
    <div class="input-group" id="group-entry">
      <div class="input-label-row">
        <label for="rr-entry-input">Entry Price</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="rr-entry-input" min="0.1" step="0.5" value="100" aria-label="Entry Price" />
        </div>
      </div>
      <input type="range" id="rr-entry-slider" min="1" max="1000" step="1" value="100" class="slider-range" aria-label="Entry Price Slider" />
    </div>

    <!-- Stop Loss Price -->
    <div class="input-group" id="group-stop">
      <div class="input-label-row">
        <label for="rr-stop-input">Stop Loss Price</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="rr-stop-input" min="0.1" step="0.5" value="95" aria-label="Stop Loss Price" />
        </div>
      </div>
      <input type="range" id="rr-stop-slider" min="1" max="1000" step="1" value="95" class="slider-range" aria-label="Stop Loss Price Slider" />
    </div>

    <!-- Take Profit Price -->
    <div class="input-group" id="group-target">
      <div class="input-label-row">
        <label for="rr-target-input">Take Profit Price</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="rr-target-input" min="0.1" step="0.5" value="115" aria-label="Take Profit Price" />
        </div>
      </div>
      <input type="range" id="rr-target-slider" min="1" max="1200" step="1" value="115" class="slider-range" aria-label="Take Profit Price Slider" />
    </div>

    <!-- Strategy Win Rate (%) -->
    <div class="input-group" id="group-winrate">
      <div class="input-label-row">
        <label for="rr-winrate-input">Strategy Win Rate</label>
        <div class="input-symbol-wrapper percent-wrapper">
          <input type="number" id="rr-winrate-input" min="1" max="99" step="1" value="40" aria-label="Strategy Win Rate" />
          <span class="percent-symbol">%</span>
        </div>
      </div>
      <input type="range" id="rr-winrate-slider" min="5" max="95" step="1" value="40" class="slider-range" aria-label="Strategy Win Rate Slider" />
    </div>

    <!-- Reset Trigger Action -->
    <div class="inputs-actions" style="margin-top: var(--space-4);">
      <Button id="rr-reset" variant="outline" size="sm" style="width: 100%;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
        Reset Calculator Inputs
      </Button>
    </div>
  </div>

  <!-- Results Section -->
  <div slot="results" class="calc-results-wrapper">
    <h3 class="results-heading">Trading Risk Metrics</h3>

    <!-- Summary Card -->
    <div style="margin-bottom: var(--space-6);">
      <Card elevation="sm" style="border-left: 4px solid var(--color-primary); padding: var(--space-4) var(--space-5); background: var(--color-bg-base);">
        <span style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted);">Recommended Trade Volume</span>
        <div id="res-rr-shares" style="font-size: 2.25rem; font-weight: 800; line-height: 1.2; margin-top: 2px; color: var(--color-primary);">30 Shares</div>
        <p id="res-rr-ratio-verdict" style="margin: 6px 0 0 0; font-size: 0.875rem; line-height: 1.5; color: var(--color-text-muted);">
          Risk-Reward Ratio is <strong>1:3.00</strong>. Buy <strong>30 shares</strong> at entry to maintain risk profile.
        </p>
      </Card>
    </div>

    <!-- Key Metrics Grid -->
    <div class="results-grid">
      <div class="result-tile">
        <span class="tile-label">Dollar Risk</span>
        <div class="tile-value" id="tile-rr-risk" style="color: var(--color-error);">$150.00</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-risk-per-share">$5.00 / share</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Dollar Reward</span>
        <div class="tile-value" id="tile-rr-reward" style="color: var(--color-success);">$450.00</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-reward-per-share">$15.00 / share</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Breakeven Win Rate</span>
        <div class="tile-value" id="tile-rr-breakeven" style="color: var(--color-accent);">25.0%</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);">Required minimum</span>
      </div>
    </div>

    <!-- Risk vs Reward Composition Bar -->
    <div class="chart-container" style="margin-bottom: var(--space-6);">
      <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: var(--space-3); text-align: center;">Risk vs. Reward Share</h4>
      <div id="rr-composition-bar" style="width: 100%; height: 28px; border-radius: var(--radius-md); overflow: hidden; display: flex; background: var(--color-border);">
        <!-- Injected via JS -->
      </div>
      <div class="chart-legend-grid">
        <span class="legend-item">
          <span class="legend-dot" style="background: var(--color-error);"></span>
          Risk (Stop Loss): <strong id="chart-rr-risk">25.0%</strong>
        </span>
        <span class="legend-item">
          <span class="legend-dot" style="background: var(--color-success);"></span>
          Reward (Target): <strong id="chart-rr-reward">75.0%</strong>
        </span>
      </div>
    </div>

    <!-- Expectancy Simulation Card -->
    <div style="margin-top: var(--space-6);">
      <Card elevation="sm" id="expectancy-card" style="border-left: 4px solid var(--color-success); padding: var(--space-4) var(--space-5); background: var(--color-bg-base);">
        <span style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted);">Strategy Expectancy</span>
        <div id="res-rr-expectancy" style="font-size: 1.5rem; font-weight: 800; line-height: 1.3; margin-top: 2px; color: var(--color-success);">+$90.00 / trade</div>
        <p id="res-rr-expectancy-details" style="margin: 6px 0 0 0; font-size: 0.875rem; line-height: 1.5; color: var(--color-text-muted);">
          At a 40% win rate, this strategy returns an average of <strong>+$90.00</strong> per trade over the long run (Positive Edge).
        </p>
      </Card>
    </div>
  </div>
</CalculatorLayout>

<script>
  function initRiskRewardCalculator() {
    // Inputs & Sliders
    const balanceInput = document.getElementById('rr-balance-input') as HTMLInputElement;
    const balanceSlider = document.getElementById('rr-balance-slider') as HTMLInputElement;
    const riskInput = document.getElementById('rr-risk-input') as HTMLInputElement;
    const riskSlider = document.getElementById('rr-risk-slider') as HTMLInputElement;
    const entryInput = document.getElementById('rr-entry-input') as HTMLInputElement;
    const entrySlider = document.getElementById('rr-entry-slider') as HTMLInputElement;
    const stopInput = document.getElementById('rr-stop-input') as HTMLInputElement;
    const stopSlider = document.getElementById('rr-stop-slider') as HTMLInputElement;
    const targetInput = document.getElementById('rr-target-input') as HTMLInputElement;
    const targetSlider = document.getElementById('rr-target-slider') as HTMLInputElement;
    const winrateInput = document.getElementById('rr-winrate-input') as HTMLInputElement;
    const winrateSlider = document.getElementById('rr-winrate-slider') as HTMLInputElement;

    // Currency
    const currencySelect = document.getElementById('rr-currency-select') as HTMLSelectElement;

    if (!balanceInput || !entryInput || !stopInput || !targetInput) return;

    // Double slider bindings helper
    function bindSlider(input: HTMLInputElement, slider: HTMLInputElement) {
      if (!input || !slider) return;
      input.addEventListener('input', () => {
        slider.value = input.value;
        validateFields();
        calculateAll();
      });
      slider.addEventListener('input', () => {
        input.value = slider.value;
        validateFields();
        calculateAll();
      });
    }

    bindSlider(balanceInput, balanceSlider);
    bindSlider(riskInput, riskSlider);
    bindSlider(entryInput, entrySlider);
    bindSlider(stopInput, stopSlider);
    bindSlider(targetInput, targetSlider);
    bindSlider(winrateInput, winrateSlider);

    if (currencySelect) {
      currencySelect.addEventListener('change', () => {
        const symbol = getCurrencySymbol(currencySelect.value);
        document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = symbol);
        calculateAll();
      });
    }

    function getCurrencySymbol(curr: string) {
      switch (curr) {
        case 'EUR': return '€';
        case 'GBP': return '£';
        case 'INR': return '₹';
        case 'JPY': return '¥';
        case 'AUD': return 'A$';
        case 'CAD': return 'C$';
        case 'SGD': return 'S$';
        case 'CHF': return 'CHF';
        default: return '$';
      }
    }

    function formatCurrency(val: number) {
      const symbol = getCurrencySymbol(currencySelect?.value || 'USD');
      return symbol + val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    // Reset button
    const resetBtn = document.getElementById('rr-reset');
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        balanceInput.value = '10000';
        balanceSlider.value = '10000';
        riskInput.value = '1.5';
        riskSlider.value = '1.5';
        entryInput.value = '100';
        entrySlider.value = '100';
        stopInput.value = '95';
        stopSlider.value = '95';
        targetInput.value = '115';
        targetSlider.value = '115';
        winrateInput.value = '40';
        winrateSlider.value = '40';
        currencySelect.value = 'USD';

        document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = '$');
        calculateAll();
      });
    }

    // Prevents mathematical nonsense (e.g. Stop Loss above Entry for buy setup)
    function validateFields() {
      const entry = parseFloat(entryInput.value) || 0;
      const stop = parseFloat(stopInput.value) || 0;
      const target = parseFloat(targetInput.value) || 0;

      // Adjust min/max bounds based on entry
      if (stop >= entry) {
        stopInput.value = (entry - 0.5).toString();
        stopSlider.value = stopInput.value;
      }
      if (target <= entry) {
        targetInput.value = (entry + 0.5).toString();
        targetSlider.value = targetInput.value;
      }
    }

    function calculateAll() {
      const balance = parseFloat(balanceInput.value) || 0;
      const riskPct = parseFloat(riskInput.value) || 0;
      const entry = parseFloat(entryInput.value) || 0;
      const stop = parseFloat(stopInput.value) || 0;
      const target = parseFloat(targetInput.value) || 0;
      const winRate = parseFloat(winrateInput.value) || 0;

      const riskAmt = balance * (riskPct / 100);
      const riskPerShare = entry - stop;
      const rewardPerShare = target - entry;

      let shares = 0;
      let ratio = 0;
      let breakevenWinRate = 0;
      let expectancy = 0;
      let totalRisk = 0;
      let totalReward = 0;

      if (riskPerShare > 0) {
        shares = riskAmt / riskPerShare;
        shares = Math.floor(shares); // round down to nearest share
        
        totalRisk = shares * riskPerShare;
        totalReward = shares * rewardPerShare;
        
        ratio = rewardPerShare / riskPerShare;
        breakevenWinRate = (riskPerShare / (riskPerShare + rewardPerShare)) * 100;
        
        // Expectancy = (Win% * Reward) - (Loss% * Risk)
        expectancy = ((winRate / 100) * totalReward) - (((100 - winRate) / 100) * totalRisk);
      }

      // Update UI elements
      const resShares = document.getElementById('res-rr-shares');
      const resRatioVerdict = document.getElementById('res-rr-ratio-verdict');

      const tileRisk = document.getElementById('tile-rr-risk');
      const tileReward = document.getElementById('tile-rr-reward');
      const tileBreakeven = document.getElementById('tile-rr-breakeven');

      const lblRiskPerShare = document.getElementById('lbl-risk-per-share');
      const lblRewardPerShare = document.getElementById('lbl-reward-per-share');

      const resExpectancy = document.getElementById('res-rr-expectancy');
      const resExpectancyDetails = document.getElementById('res-rr-expectancy-details');
      const expectancyCard = document.getElementById('expectancy-card');

      const compBar = document.getElementById('rr-composition-bar');
      const chartRisk = document.getElementById('chart-rr-risk');
      const chartReward = document.getElementById('chart-rr-reward');

      if (resShares) resShares.textContent = `${shares.toLocaleString()} Shares`;
      if (resRatioVerdict) {
        resRatioVerdict.innerHTML = `Risk-Reward Ratio is <strong>1:${ratio.toFixed(2)}</strong>. Buy <strong>${shares.toLocaleString()} shares</strong> at entry to maintain risk profile.`;
      }

      if (tileRisk) tileRisk.textContent = formatCurrency(totalRisk);
      if (tileReward) tileReward.textContent = formatCurrency(totalReward);
      if (tileBreakeven) tileBreakeven.textContent = `${breakevenWinRate.toFixed(1)}%`;

      if (lblRiskPerShare) lblRiskPerShare.textContent = `${formatCurrency(riskPerShare)} / share`;
      if (lblRewardPerShare) lblRewardPerShare.textContent = `${formatCurrency(rewardPerShare)} / share`;

      if (resExpectancy) {
        if (expectancy >= 0) {
          resExpectancy.textContent = `+${formatCurrency(expectancy)} / trade`;
          resExpectancy.style.color = 'var(--color-success)';
          if (expectancyCard) expectancyCard.style.borderLeftColor = 'var(--color-success)';
        } else {
          resExpectancy.textContent = `-${formatCurrency(Math.abs(expectancy))} / trade`;
          resExpectancy.style.color = 'var(--color-error)';
          if (expectancyCard) expectancyCard.style.borderLeftColor = 'var(--color-error)';
        }
      }

      if (resExpectancyDetails) {
        if (expectancy >= 0) {
          resExpectancyDetails.innerHTML = `At a ${winRate.toFixed(0)}% win rate, this strategy returns an average of <strong>+${formatCurrency(expectancy)}</strong> per trade over the long run (Positive Edge).`;
        } else {
          resExpectancyDetails.innerHTML = `At a ${winRate.toFixed(0)}% win rate, this strategy returns an average of <strong style="color: var(--color-error);">${formatCurrency(expectancy)}</strong> per trade over the long run (Negative Edge). **Warning: You will lose money over time.**`;
        }
      }

      // Update Chart composition bar
      if (chartRisk) {
        const riskShare = (riskPerShare / (riskPerShare + rewardPerShare)) * 100;
        chartRisk.textContent = `${riskShare.toFixed(1)}%`;
      }
      if (chartReward) {
        const rewardShare = (rewardPerShare / (riskPerShare + rewardPerShare)) * 100;
        chartReward.textContent = `${rewardShare.toFixed(1)}%`;
      }

      if (compBar) {
        const totalDelta = riskPerShare + rewardPerShare;
        if (totalDelta > 0) {
          const rPct = (riskPerShare / totalDelta) * 100;
          const wPct = (rewardPerShare / totalDelta) * 100;

          compBar.innerHTML = `
            <div style="width: ${rPct.toFixed(1)}%; height: 100%; background: var(--color-error); transition: width 0.3s ease;"></div>
            <div style="width: ${wPct.toFixed(1)}%; height: 100%; background: var(--color-success); transition: width 0.3s ease;"></div>
          `;
        } else {
          compBar.innerHTML = `<div style="width: 100%; height: 100%; background: var(--color-border);"></div>`;
        }
      }
    }

    // Trigger initial calculation
    calculateAll();
    
    // Connect copy results button listener
    window.addEventListener('copy-calculator-results', () => {
      const text = `Risk-Reward Ratio Analysis Summary:\n` +
                   `Position Size: ${document.getElementById('res-rr-shares')?.textContent}\n` +
                   `Risk-Reward Ratio: 1:${(parseFloat(targetInput.value) - parseFloat(entryInput.value)) / (parseFloat(entryInput.value) - parseFloat(stopInput.value))}\n` +
                   `Stated Risk: ${document.getElementById('tile-rr-risk')?.textContent}\n` +
                   `Stated Reward: ${document.getElementById('tile-rr-reward')?.textContent}\n` +
                   `Breakeven Win Rate: ${document.getElementById('tile-rr-breakeven')?.textContent}\n` +
                   `Expected Value: ${document.getElementById('res-rr-expectancy')?.textContent}`;
      
      navigator.clipboard.writeText(text).then(() => {
        window.dispatchEvent(new CustomEvent('calculator-copied-success'));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initRiskRewardCalculator);
  document.addEventListener('astro:after-swap', initRiskRewardCalculator);
</script>

<style>
  /* Inputs wrapper styling */
  .calc-inputs-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .hidden {
    display: none !important;
  }

  #group-currency {
    margin-bottom: var(--space-3);
  }

  .calculator-mode-selector {
    margin-bottom: var(--space-2);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-group label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  .input-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .input-label-row label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  /* Input symbol wrapper */
  .input-symbol-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 10px;
    width: 145px;
    height: 38px;
    transition: border-color var(--transition-fast);
  }

  .input-symbol-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .currency-symbol {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-right: 4px;
  }

  .input-symbol-wrapper input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-base);
    text-align: right;
    outline: none;
  }

  .input-symbol-wrapper input::-webkit-outer-spin-button,
  .input-symbol-wrapper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .percent-wrapper input, .units-wrapper input {
    text-align: left;
  }

  .percent-symbol {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-left: 4px;
    white-space: nowrap;
  }

  /* Slider range */
  .slider-range {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    outline: none;
    margin: 6px 0;
    cursor: pointer;
  }

  .slider-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--color-bg-surface);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), background-color var(--transition-fast);
  }

  .slider-range::-webkit-slider-thumb:hover {
    transform: scale(1.1);
    background: var(--color-primary-hover);
  }

  .currency-select {
    height: 44px;
    padding: 0 var(--space-3);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    outline: none;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .currency-select:focus {
    border-color: var(--color-primary);
  }

  .table-container {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-bg-base);
  }

  .results-table th, .results-table td {
    border-bottom: 1px solid var(--color-border);
  }

  .results-table tr:last-child td {
    border-bottom: none;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .result-tile {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tile-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .tile-value {
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .chart-legend-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-2) var(--space-4);
    font-size: 0.75rem;
    color: var(--color-text-light);
    margin-top: var(--space-2);
    padding: 0 4px;
  }


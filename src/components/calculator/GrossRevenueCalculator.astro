---
import CalculatorLayout from './CalculatorLayout.astro';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
---

<CalculatorLayout
  title="Gross Revenue Calculator"
  description="Calculate your company's top-line gross revenue, net revenue after returns and discounts, gross profit, and profit margins. Reconcile sales volume and pricing with accurate GAAP revenue accounting."
  category="Business & Operations"
>
  <!-- Inputs Section -->
  <div slot="inputs" class="calc-inputs-wrapper" id="gross-revenue-calculator">
    
    <!-- Step 1: Currency & Unit Sales -->
    <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-3);">1. Sales Volume & Pricing</h3>
    
    <!-- Currency Selector -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="gr-currency-select">Currency</label>
        <select id="gr-currency-select" class="currency-select" aria-label="Select Currency">
          <option value="USD" selected>USD ($) - US Dollar</option>
          <option value="EUR">EUR (€) - Euro</option>
          <option value="GBP">GBP (£) - British Pound</option>
          <option value="INR">INR (₹) - Indian Rupee</option>
          <option value="JPY">JPY (¥) - Japanese Yen</option>
          <option value="AUD">AUD (A$) - Australian Dollar</option>
          <option value="CAD">CAD (C$) - Canadian Dollar</option>
          <option value="SGD">SGD (S$) - Singapore Dollar</option>
          <option value="CHF">CHF (CHF) - Swiss Franc</option>
        </select>
      </div>
    </div>

    <!-- Units Sold -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="gr-units-input">Total Units / Contracts Sold</label>
        <div class="input-symbol-wrapper">
          <input type="number" id="gr-units-input" min="1" step="50" value="1000" aria-label="Units Sold" style="text-align: left;" />
          <span class="percent-symbol">units</span>
        </div>
      </div>
      <input type="range" id="gr-units-slider" min="10" max="10000" step="50" value="1000" class="slider-range" aria-label="Units Sold Slider" />
    </div>

    <!-- Average Price Per Unit -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="gr-price-input">Average Selling Price Per Unit</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="gr-price-input" min="1" step="5" value="150" aria-label="Average Price Per Unit" />
        </div>
      </div>
      <input type="range" id="gr-price-slider" min="1" max="1000" step="5" value="150" class="slider-range" aria-label="Price Per Unit Slider" />
    </div>

    <!-- Step 2: Revenue Deductions & Adjustments -->
    <div style="margin-top: var(--space-5);">
      <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-4);">2. Deductions & Returns</h3>
      
      <!-- Product Returns & Allowances -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="gr-returns-input">Product Returns & Customer Allowances</label>
          <div class="input-symbol-wrapper">
            <span class="currency-symbol">$</span>
            <input type="number" id="gr-returns-input" min="0" step="250" value="7500" aria-label="Product Returns and Allowances" />
          </div>
        </div>
        <input type="range" id="gr-returns-slider" min="0" max="30000" step="250" value="7500" class="slider-range" aria-label="Returns Slider" />
      </div>

      <!-- Promotional Discounts & Coupons -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="gr-discounts-input">Promotional Discounts & Coupons</label>
          <div class="input-symbol-wrapper">
            <span class="currency-symbol">$</span>
            <input type="number" id="gr-discounts-input" min="0" step="250" value="4500" aria-label="Promotional Discounts and Coupons" />
          </div>
        </div>
        <input type="range" id="gr-discounts-slider" min="0" max="30000" step="250" value="4500" class="slider-range" aria-label="Discounts Slider" />
      </div>
    </div>

    <!-- Step 3: Cost of Goods Sold -->
    <div style="margin-top: var(--space-5);">
      <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-4);">3. Cost of Goods Sold (COGS)</h3>

      <!-- Cost of Goods Sold -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="gr-cogs-input">Total Cost of Goods Sold (COGS)</label>
          <div class="input-symbol-wrapper">
            <span class="currency-symbol">$</span>
            <input type="number" id="gr-cogs-input" min="0" step="500" value="52500" aria-label="Cost of Goods Sold" />
          </div>
        </div>
        <input type="range" id="gr-cogs-slider" min="0" max="100000" step="500" value="52500" class="slider-range" aria-label="COGS Slider" />
      </div>
    </div>

    <!-- Reset Trigger -->
    <div class="inputs-actions" style="margin-top: var(--space-6);">
      <Button id="gr-reset" variant="outline" size="sm" style="width: 100%;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
        Reset Calculator Inputs
      </Button>
    </div>
  </div>

  <!-- Results Section -->
  <div slot="results" class="calc-results-wrapper">
    <h3 class="results-heading">Revenue & Profitability Summary</h3>

    <!-- Core Payout Displays -->
    <div class="net-value-container" style="display: flex; gap: var(--space-4); margin-bottom: var(--space-5);">
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-success);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Total Gross Revenue</span>
        <div id="res-gr-gross-rev" style="font-size: 1.75rem; font-weight: 800; color: var(--color-success); margin-top: 4px;">$150,000.00</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-gr-net-rev">Net Revenue: $138,000.00</span>
      </div>
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-primary);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Gross Profit</span>
        <div id="res-gr-gross-profit" style="font-size: 1.75rem; font-weight: 800; color: var(--color-primary); margin-top: 4px;">$85,500.00</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-gr-margin">Gross Margin: 57.00%</span>
      </div>
    </div>

    <!-- Optimization Verdict -->
    <div style="margin-bottom: var(--space-6);">
      <Card elevation="sm" id="gr-verdict-card" style="border-left: 4px solid var(--color-success); padding: var(--space-4) var(--space-5); background: var(--color-bg-base);">
        <span style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted);">Top-Line Revenue Diagnosis</span>
        <p id="res-gr-verdict-text" style="margin: 4px 0 0 0; font-size: 0.875rem; line-height: 1.5; color: var(--color-text-muted);">
          Selling <strong>1,000 units</strong> at <strong>$150.00/unit</strong> generates <strong>$150,000.00</strong> in top-line Gross Revenue. After <strong>$12,000.00</strong> in returns and discounts (8.00%), Net Revenue is <strong>$138,000.00</strong> and Gross Profit is <strong>$85,500.00</strong>.
        </p>
      </Card>
    </div>

    <!-- Key Metrics Grid -->
    <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: var(--space-3);">Sales & Cost Waterfall Breakdown</h4>
    <div class="results-grid gr-metrics-grid">
      <div class="result-tile">
        <span class="tile-label">Net Revenue</span>
        <div class="tile-value" id="tile-gr-net-rev" style="color: var(--color-success);">$138,000</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-gr-deductions-desc">After $12,000 deductions</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Deduction Ratio</span>
        <div class="tile-value" id="tile-gr-deduction-pct" style="color: var(--color-warning);">8.00%</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);">Returns & discount drag</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Gross Margin</span>
        <div class="tile-value" id="tile-gr-margin-pct" style="color: var(--color-primary);">57.00%</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);">Gross Profit / Gross Revenue</span>
      </div>
    </div>
  </div>
</CalculatorLayout>

<script>
  function initGrCalculator() {
    // Select elements
    const currencySelect = document.getElementById('gr-currency-select') as HTMLSelectElement;

    const unitsInput = document.getElementById('gr-units-input') as HTMLInputElement;
    const unitsSlider = document.getElementById('gr-units-slider') as HTMLInputElement;
    const priceInput = document.getElementById('gr-price-input') as HTMLInputElement;
    const priceSlider = document.getElementById('gr-price-slider') as HTMLInputElement;

    const returnsInput = document.getElementById('gr-returns-input') as HTMLInputElement;
    const returnsSlider = document.getElementById('gr-returns-slider') as HTMLInputElement;
    const discountsInput = document.getElementById('gr-discounts-input') as HTMLInputElement;
    const discountsSlider = document.getElementById('gr-discounts-slider') as HTMLInputElement;
    const cogsInput = document.getElementById('gr-cogs-input') as HTMLInputElement;
    const cogsSlider = document.getElementById('gr-cogs-slider') as HTMLInputElement;

    if (!unitsInput || !currencySelect || !priceInput) return;

    // Slider bindings
    function bindSlider(input: HTMLInputElement, slider: HTMLInputElement) {
      if (!input || !slider) return;
      input.addEventListener('input', () => {
        slider.value = input.value;
        calculateAll();
      });
      slider.addEventListener('input', () => {
        input.value = slider.value;
        calculateAll();
      });
    }

    bindSlider(unitsInput, unitsSlider);
    bindSlider(priceInput, priceSlider);
    bindSlider(returnsInput, returnsSlider);
    bindSlider(discountsInput, discountsSlider);
    bindSlider(cogsInput, cogsSlider);

    // Currency updates
    currencySelect.addEventListener('change', () => {
      const symbol = getCurrencySymbol(currencySelect.value);
      document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = symbol);
      calculateAll();
    });

    function getCurrencySymbol(curr: string) {
      switch (curr) {
        case 'EUR': return '€';
        case 'GBP': return '£';
        case 'INR': return '₹';
        case 'JPY': return '¥';
        case 'AUD': return 'A$';
        case 'CAD': return 'C$';
        case 'SGD': return 'S$';
        case 'CHF': return 'CHF';
        default: return '$';
      }
    }

    // Reset button
    const resetBtn = document.getElementById('gr-reset');
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        unitsInput.value = '1000';
        unitsSlider.value = '1000';
        priceInput.value = '150';
        priceSlider.value = '150';

        returnsInput.value = '7500';
        returnsSlider.value = '7500';
        discountsInput.value = '4500';
        discountsSlider.value = '4500';
        cogsInput.value = '52500';
        cogsSlider.value = '52500';

        currencySelect.value = 'USD';
        document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = '$');
        calculateAll();
      });
    }

    function formatCurrency(val: number) {
      const symbol = getCurrencySymbol(currencySelect.value);
      return symbol + val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function calculateAll() {
      // Inputs variables
      const units = parseFloat(unitsInput.value) || 0;
      const price = parseFloat(priceInput.value) || 0;

      const returnsVal = parseFloat(returnsInput.value) || 0;
      const discountsVal = parseFloat(discountsInput.value) || 0;
      const cogsVal = parseFloat(cogsInput.value) || 0;

      // Revenue Math
      const grossRevenue = units * price;
      const totalDeductions = returnsVal + discountsVal;
      const netRevenue = Math.max(0, grossRevenue - totalDeductions);
      const grossProfit = netRevenue - cogsVal;

      const grossMarginPct = grossRevenue > 0 ? (grossProfit / grossRevenue) * 100 : 0;
      const deductionPct = grossRevenue > 0 ? (totalDeductions / grossRevenue) * 100 : 0;

      // DOM Updates
      const resGrossRev = document.getElementById('res-gr-gross-rev');
      const resGrossProfit = document.getElementById('res-gr-gross-profit');
      const lblNetRev = document.getElementById('lbl-gr-net-rev');
      const lblMargin = document.getElementById('lbl-gr-margin');

      if (resGrossRev) resGrossRev.textContent = formatCurrency(grossRevenue);
      if (resGrossProfit) resGrossProfit.textContent = formatCurrency(grossProfit);
      if (lblNetRev) lblNetRev.textContent = `Net Revenue: ${formatCurrency(netRevenue)}`;
      if (lblMargin) lblMargin.textContent = `Gross Margin: ${grossMarginPct.toFixed(2)}%`;

      // Verdict card and text
      const verdictText = document.getElementById('res-gr-verdict-text');
      if (verdictText) {
        verdictText.innerHTML = `Selling <strong>${units.toLocaleString()} units</strong> at <strong>${formatCurrency(price)}/unit</strong> generates <strong>${formatCurrency(grossRevenue)}</strong> in top-line Gross Revenue. After <strong>${formatCurrency(totalDeductions)}</strong> in returns & discounts (<strong>${deductionPct.toFixed(2)}%</strong>), Net Revenue is <strong>${formatCurrency(netRevenue)}</strong> and Gross Profit is <strong>${formatCurrency(grossProfit)}</strong> (<strong>${grossMarginPct.toFixed(2)}% Gross Margin</strong>).`;
      }

      // Details Tiles Updates
      const tileNetRev = document.getElementById('tile-gr-net-rev');
      const lblDeductionsDesc = document.getElementById('lbl-gr-deductions-desc');
      const tileDeductionPct = document.getElementById('tile-gr-deduction-pct');
      const tileMarginPct = document.getElementById('tile-gr-margin-pct');

      if (tileNetRev) tileNetRev.textContent = formatCurrency(netRevenue).split('.')[0];
      if (lblDeductionsDesc) lblDeductionsDesc.textContent = `After ${formatCurrency(totalDeductions)} deductions`;

      if (tileDeductionPct) tileDeductionPct.textContent = deductionPct.toFixed(2) + '%';
      if (tileMarginPct) tileMarginPct.textContent = grossMarginPct.toFixed(2) + '%';
    }

    // Trigger initial calculation
    calculateAll();

    // Clipboard copy results handler
    window.addEventListener('copy-calculator-results', () => {
      const text = `Gross Revenue & Sales Reconciliation:\n` +
                   `Volume: ${unitsInput.value} units @ ${priceInput.value}/unit\n` +
                   `Gross Revenue: ${document.getElementById('res-gr-gross-rev')?.textContent}\n` +
                   `Returns: ${returnsInput.value} | Discounts: ${discountsInput.value} | COGS: ${cogsInput.value}\n` +
                   `Net Revenue: ${document.getElementById('lbl-gr-net-rev')?.textContent}\n` +
                   `Gross Profit: ${document.getElementById('res-gr-gross-profit')?.textContent} (${document.getElementById('lbl-gr-margin')?.textContent})\n` +
                   `Diagnosis: ${document.getElementById('res-gr-verdict-text')?.textContent}`;
      
      navigator.clipboard.writeText(text).then(() => {
        window.dispatchEvent(new CustomEvent('calculator-copied-success'));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initGrCalculator);
  document.addEventListener('astro:after-swap', initGrCalculator);
</script>

<style>
  .calc-inputs-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .input-label-row label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  /* Input symbol wrapper */
  .input-symbol-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 10px;
    width: 145px;
    height: 38px;
    transition: border-color var(--transition-fast);
  }

  .input-symbol-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .currency-symbol {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-right: 4px;
  }

  .input-symbol-wrapper input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-base);
    text-align: right;
    outline: none;
  }

  .input-symbol-wrapper input::-webkit-outer-spin-button,
  .input-symbol-wrapper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .percent-symbol {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-left: 4px;
    white-space: nowrap;
  }

  /* Currency select menu */
  .currency-select {
    width: 100%;
    max-width: 250px;
    height: 38px;
    padding: 0 10px;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-base);
    outline: none;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .currency-select:focus {
    border-color: var(--color-primary);
  }

  /* Slider range */
  .slider-range {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    outline: none;
    margin: 6px 0;
    cursor: pointer;
  }

  .slider-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--color-bg-surface);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), background-color var(--transition-fast);
  }

  .slider-range::-webkit-slider-thumb:hover {
    transform: scale(1.1);
    background: var(--color-primary-hover);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .result-tile {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tile-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .tile-value {
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .net-value-container {
      flex-direction: column;
    }
  }

  @media (max-width: 420px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 500px) {
    .input-label-row {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-2);
    }

    .input-symbol-wrapper {
      width: 100% !important;
      max-width: 100% !important;
    }

    .currency-select {
      max-width: 100% !important;
    }
  }
</style>

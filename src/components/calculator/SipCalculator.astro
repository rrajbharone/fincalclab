---
import CalculatorLayout from './CalculatorLayout.astro';
import Button from '../ui/Button.astro';
---

<CalculatorLayout
  title="Lumpsum vs SIP Comparison Calculator"
  description="Compare the wealth generated by a one-time lumpsum investment versus a systematic monthly investment plan (SIP) over time."
  category="Investments"
>
  <!-- Inputs Section -->
  <div slot="inputs" class="calc-inputs-wrapper" id="sip-calc">
    <div class="input-group">
      <div class="input-label-row">
        <label for="sip-currency-select">Currency</label>
        <select id="sip-currency-select" class="currency-select" aria-label="Select Currency">
          <option value="USD" selected>USD ($) - US Dollar</option>
          <option value="EUR">EUR (€) - Euro</option>
          <option value="GBP">GBP (£) - British Pound</option>
          <option value="INR">INR (₹) - Indian Rupee</option>
          <option value="JPY">JPY (¥) - Japanese Yen</option>
          <option value="AUD">AUD (A$) - Australian Dollar</option>
          <option value="CAD">CAD (C$) - Canadian Dollar</option>
          <option value="CHF">CHF (CHF) - Swiss Franc</option>
          <option value="CNY">CNY (¥) - Chinese Yuan</option>
          <option value="SGD">SGD (S$) - Singapore Dollar</option>
        </select>
      </div>
    </div>

    <div class="input-group">
      <div class="input-label-row">
        <label for="lumpsum-input">Lumpsum Investment</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="lumpsum-input" min="0" max="10000000" value="100000" aria-label="Lumpsum Investment Amount" />
        </div>
      </div>
      <input type="range" id="lumpsum-slider" min="1000" max="10000000" step="5000" value="100000" class="slider-range" aria-label="Lumpsum Investment Slider" />
      <div class="slider-ticks">
        <span>1k</span>
        <span>5M</span>
        <span>10M</span>
      </div>
    </div>

    <div class="input-group">
      <div class="input-label-row">
        <label for="sip-input">Monthly SIP Amount</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="sip-input" min="0" max="1000000" value="5000" aria-label="Monthly SIP Amount" />
        </div>
      </div>
      <input type="range" id="sip-slider" min="500" max="1000000" step="500" value="5000" class="slider-range" aria-label="Monthly SIP Slider" />
      <div class="slider-ticks">
        <span>500</span>
        <span>500k</span>
        <span>1M</span>
      </div>
    </div>

    <div class="input-row-grid">
      <div class="input-group">
        <div class="input-label-row">
          <label for="rate-input">Expected Return (p.a.)</label>
          <div class="input-symbol-wrapper percent-wrapper">
            <input type="number" id="rate-input" min="1" max="30" step="0.1" value="12" aria-label="Expected annual return percentage" />
            <span class="percent-symbol">%</span>
          </div>
        </div>
        <input type="range" id="rate-slider" min="1" max="30" step="0.5" value="12" class="slider-range" aria-label="Expected return slider" />
      </div>

      <div class="input-group">
        <div class="input-label-row">
          <label for="period-input">Investment Period</label>
          <div class="input-symbol-wrapper years-wrapper">
            <input type="number" id="period-input" min="1" max="40" value="10" aria-label="Investment period in years" />
            <span class="years-symbol">Yr</span>
          </div>
        </div>
        <input type="range" id="period-slider" min="1" max="40" step="1" value="10" class="slider-range" aria-label="Investment period slider" />
      </div>
    </div>

    <div class="inputs-actions">
      <Button id="sip-reset" variant="outline" size="sm" style="width: 100%;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
        Reset Inputs
      </Button>
    </div>
  </div>

  <!-- Results Section -->
  <div slot="results" class="calc-results-wrapper">
    <h3 class="results-heading">Projections Breakdown</h3>
    
    <div class="comparison-cards-grid">
      <!-- Lumpsum Card -->
      <div class="comparison-card lumpsum-res-card">
        <div class="comp-card-header">
          <span class="indicator-dot lumpsum-dot"></span>
          <h4>Lumpsum</h4>
        </div>
        <div class="metric-row">
          <span class="metric-label">Total Invested</span>
          <span class="metric-val" id="lumpsum-invested">$0</span>
        </div>
        <div class="metric-row">
          <span class="metric-label">Est. Returns</span>
          <span class="metric-val text-success" id="lumpsum-gains">$0</span>
        </div>
        <div class="metric-row divider">
          <span class="metric-label font-bold">Total Wealth</span>
          <span class="metric-val font-bold text-primary" id="lumpsum-value">$0</span>
        </div>
      </div>

      <!-- SIP Card -->
      <div class="comparison-card sip-res-card">
        <div class="comp-card-header">
          <span class="indicator-dot sip-dot"></span>
          <h4>SIP Plan</h4>
        </div>
        <div class="metric-row">
          <span class="metric-label">Total Invested</span>
          <span class="metric-val" id="sip-invested">$0</span>
        </div>
        <div class="metric-row">
          <span class="metric-label">Est. Returns</span>
          <span class="metric-val text-success" id="sip-gains">$0</span>
        </div>
        <div class="metric-row divider">
          <span class="metric-label font-bold">Total Wealth</span>
          <span class="metric-val font-bold text-accent" id="sip-value">$0</span>
        </div>
      </div>
    </div>

    <!-- Recommendation Box -->
    <div class="recommendation-box" id="sip-recommendation-box">
      <div class="box-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
      </div>
      <p id="sip-recommendation" class="box-text">Calculating details...</p>
    </div>

    <!-- Growth Graph Card -->
    <div class="chart-wrapper">
      <h4 class="chart-title">Wealth Growth Over Time</h4>
      <div class="chart-container">
        <svg id="sip-growth-svg" viewBox="0 0 500 280" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
          <!-- Gridlines and ticks -->
          <g id="chart-gridlines"></g>
          <!-- Chart Paths -->
          <path id="chart-path-lumpsum" fill="none" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          <path id="chart-path-sip" fill="none" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <div class="chart-legend">
        <div class="legend-item">
          <span class="legend-dot lumpsum-dot"></span>
          <span>Lumpsum</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot sip-dot"></span>
          <span>SIP</span>
        </div>
      </div>
    </div>
  </div>
</CalculatorLayout>

<script>
  function initSipCalculator() {
    const root = document.getElementById('sip-calc');
    if (!root) return;

    // Grab elements
    const lumpsumInput = root.querySelector('#lumpsum-input') as HTMLInputElement;
    const lumpsumSlider = root.querySelector('#lumpsum-slider') as HTMLInputElement;
    const sipInput = root.querySelector('#sip-input') as HTMLInputElement;
    const sipSlider = root.querySelector('#sip-slider') as HTMLInputElement;
    const rateInput = root.querySelector('#rate-input') as HTMLInputElement;
    const rateSlider = root.querySelector('#rate-slider') as HTMLInputElement;
    const periodInput = root.querySelector('#period-input') as HTMLInputElement;
    const periodSlider = root.querySelector('#period-slider') as HTMLInputElement;
    const resetBtn = root.querySelector('#sip-reset');
    const currencySelect = root.querySelector('#sip-currency-select') as HTMLSelectElement;

    if (!lumpsumInput || !lumpsumSlider || !sipInput || !sipSlider || !rateInput || !rateSlider || !periodInput || !periodSlider || !currencySelect) return;

    const CURRENCIES: Record<string, { symbol: string; locale: string }> = {
      USD: { symbol: '$', locale: 'en-US' },
      EUR: { symbol: '€', locale: 'de-DE' },
      GBP: { symbol: '£', locale: 'en-GB' },
      INR: { symbol: '₹', locale: 'en-IN' },
      JPY: { symbol: '¥', locale: 'ja-JP' },
      AUD: { symbol: 'A$', locale: 'en-AU' },
      CAD: { symbol: 'C$', locale: 'en-CA' },
      CHF: { symbol: 'CHF', locale: 'de-CH' },
      CNY: { symbol: '¥', locale: 'zh-CN' },
      SGD: { symbol: 'S$', locale: 'en-SG' }
    };

    const getSelectedCurrency = () => {
      return currencySelect ? currencySelect.value : 'USD';
    };

    // Helper to format currency
    const formatCurrency = (val: number) => {
      const curr = getSelectedCurrency();
      const config = CURRENCIES[curr] || CURRENCIES.USD;
      return new Intl.NumberFormat(config.locale, {
        style: 'currency',
        currency: curr,
        maximumFractionDigits: 0
      }).format(val);
    };

    const updateCurrencyLabels = () => {
      const curr = getSelectedCurrency();
      const config = CURRENCIES[curr] || CURRENCIES.USD;
      root.querySelectorAll('.currency-symbol').forEach((el) => {
        el.textContent = config.symbol;
      });
    };

    currencySelect.addEventListener('change', () => {
      updateCurrencyLabels();
      calculateResults();
    });

    // Calculate future values
    const calculateResults = () => {
      const lumpsumPrincipal = parseFloat(lumpsumInput.value) || 0;
      const sipMonthlyAmount = parseFloat(sipInput.value) || 0;
      const annualRate = parseFloat(rateInput.value) || 0;
      const years = parseInt(periodInput.value) || 0;

      // Calculations
      const monthlyRate = (annualRate / 100) / 12;
      const months = years * 12;

      // 1. Lumpsum Growth: FV = P * (1 + r)^t
      const lumpsumInvested = lumpsumPrincipal;
      const lumpsumValue = lumpsumPrincipal * Math.pow(1 + (annualRate / 100), years);
      const lumpsumGains = Math.max(0, lumpsumValue - lumpsumInvested);

      // 2. SIP Growth: FV = P * [((1 + i)^n - 1) / i] * (1 + i)
      const sipInvested = sipMonthlyAmount * months;
      let sipValue = 0;
      if (monthlyRate > 0) {
        sipValue = sipMonthlyAmount * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate) * (1 + monthlyRate);
      } else {
        sipValue = sipMonthlyAmount * months;
      }
      const sipGains = Math.max(0, sipValue - sipInvested);

      // Update Results DOM
      updateDOM({
        lumpsumInvested, lumpsumGains, lumpsumValue,
        sipInvested, sipGains, sipValue,
        years, annualRate
      });
    };

    const updateDOM = (data: {
      lumpsumInvested: number; lumpsumGains: number; lumpsumValue: number;
      sipInvested: number; sipGains: number; sipValue: number;
      years: number; annualRate: number;
    }) => {
      // Numerical outputs in results panel
      const lInvestedEl = document.getElementById('lumpsum-invested');
      const lGainsEl = document.getElementById('lumpsum-gains');
      const lValueEl = document.getElementById('lumpsum-value');
      
      const sInvestedEl = document.getElementById('sip-invested');
      const sGainsEl = document.getElementById('sip-gains');
      const sValueEl = document.getElementById('sip-value');

      const recommendationEl = document.getElementById('sip-recommendation');

      if (lInvestedEl) lInvestedEl.textContent = formatCurrency(data.lumpsumInvested);
      if (lGainsEl) lGainsEl.textContent = formatCurrency(data.lumpsumGains);
      if (lValueEl) lValueEl.textContent = formatCurrency(data.lumpsumValue);

      if (sInvestedEl) sInvestedEl.textContent = formatCurrency(data.sipInvested);
      if (sGainsEl) sGainsEl.textContent = formatCurrency(data.sipGains);
      if (sValueEl) sValueEl.textContent = formatCurrency(data.sipValue);

      if (recommendationEl) {
        const diff = Math.abs(data.lumpsumValue - data.sipValue);
        const winner = data.lumpsumValue > data.sipValue ? 'Lumpsum' : 'SIP';
        const loser = winner === 'Lumpsum' ? 'SIP' : 'Lumpsum';
        
        recommendationEl.innerHTML = `
          <strong>${winner} yields higher wealth!</strong> Under these settings, investing a one-time lumpsum of 
          ${formatCurrency(data.lumpsumInvested)} returns <strong>${formatCurrency(data.lumpsumValue)}</strong> after ${data.years} years. 
          In comparison, a monthly systematic investment of ${formatCurrency(parseFloat(sipInput.value))} 
          (total invested: ${formatCurrency(data.sipInvested)}) yields <strong>${formatCurrency(data.sipValue)}</strong>. 
          The ${winner} approach outperforms the ${loser} approach by <strong>${formatCurrency(diff)}</strong>.
        `;
      }

      // Draw SVG Chart
      drawChart(data);
    };

    const drawChart = (data: {
      lumpsumInvested: number; lumpsumValue: number;
      sipInvested: number; sipValue: number;
      years: number; annualRate: number;
    }) => {
      const chartSvg = document.getElementById('sip-growth-svg') as unknown as SVGSVGElement;
      if (!chartSvg) return;

      const width = 500;
      const height = 280;
      const paddingLeft = 60;
      const paddingRight = 20;
      const paddingTop = 20;
      const paddingBottom = 40;

      const chartWidth = width - paddingLeft - paddingRight;
      const chartHeight = height - paddingTop - paddingBottom;

      // Calculate data points over years
      const lumpsumPoints: { x: number; y: number }[] = [];
      const sipPoints: { x: number; y: number }[] = [];

      const annualRate = data.annualRate / 100;
      const monthlyRate = annualRate / 12;

      for (let yr = 0; yr <= data.years; yr++) {
        // Lumpsum value at year yr
        const lVal = data.lumpsumInvested * Math.pow(1 + annualRate, yr);
        lumpsumPoints.push({ x: yr, y: lVal });

        // SIP value at year yr
        const months = yr * 12;
        let sVal = 0;
        if (monthlyRate > 0) {
          sVal = parseFloat(sipInput.value) * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate) * (1 + monthlyRate);
        } else {
          sVal = parseFloat(sipInput.value) * months;
        }
        sipPoints.push({ x: yr, y: sVal });
      }

      // Max value for scaling Y (ensure at least some positive height)
      const maxVal = Math.max(
        lumpsumPoints[lumpsumPoints.length - 1].y || 1000,
        sipPoints[sipPoints.length - 1].y || 1000
      );

      // Coordinate mapping helpers
      const getX = (yr: number) => paddingLeft + (yr / data.years) * chartWidth;
      const getY = (val: number) => paddingTop + chartHeight - (val / maxVal) * chartHeight;

      // Generate paths
      let lumpsumPathD = `M ${getX(0)} ${getY(lumpsumPoints[0].y)}`;
      let sipPathD = `M ${getX(0)} ${getY(sipPoints[0].y)}`;

      for (let i = 1; i < lumpsumPoints.length; i++) {
        lumpsumPathD += ` L ${getX(i)} ${getY(lumpsumPoints[i].y)}`;
        sipPathD += ` L ${getX(i)} ${getY(sipPoints[i].y)}`;
      }

      // Update paths in DOM
      const lPath = document.getElementById('chart-path-lumpsum');
      const sPath = document.getElementById('chart-path-sip');
      if (lPath) lPath.setAttribute('d', lumpsumPathD);
      if (sPath) sPath.setAttribute('d', sipPathD);

      // Update gridlines and axes labels
      const yAxisTicks = 4;
      const gridlinesContainer = document.getElementById('chart-gridlines');
      if (gridlinesContainer) {
        let gridHtml = '';
        
        // Horizontal gridlines and Y-axis labels
        for (let i = 0; i <= yAxisTicks; i++) {
          const val = (maxVal / yAxisTicks) * i;
          const y = getY(val);
          
          const curr = getSelectedCurrency();
          const config = CURRENCIES[curr] || CURRENCIES.USD;
          let label = '';
          if (val >= 1000000) {
            label = `${config.symbol}${(val / 1000000).toFixed(1)}M`;
          } else if (val >= 1000) {
            label = `${config.symbol}${(val / 1000).toFixed(0)}k`;
          } else {
            label = `${config.symbol}${val.toFixed(0)}`;
          }

          gridHtml += `
            <line x1="${paddingLeft}" y1="${y}" x2="${width - paddingRight}" y2="${y}" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,4" />
            <text x="${paddingLeft - 10}" y="${y + 4}" font-size="10" font-family="var(--font-sans)" font-weight="500" fill="var(--color-text-light)" text-anchor="end">${label}</text>
          `;
        }

        // Vertical gridlines and X-axis labels
        const xAxisTicks = Math.min(data.years, 5);
        for (let i = 0; i <= xAxisTicks; i++) {
          const tickYr = Math.round((data.years / xAxisTicks) * i);
          const x = getX(tickYr);
          gridHtml += `
            <line x1="${x}" y1="${paddingTop}" x2="${x}" y2="${height - paddingBottom}" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,4" />
            <text x="${x}" y="${height - paddingBottom + 18}" font-size="10" font-family="var(--font-sans)" font-weight="500" fill="var(--color-text-light)" text-anchor="middle">Yr ${tickYr}</text>
          `;
        }

        gridlinesContainer.innerHTML = gridHtml;
      }
    };

    // Synchronize inputs & sliders
    const setupSync = (input: HTMLInputElement, slider: HTMLInputElement, callback: () => void) => {
      const updateFromInput = () => {
        let val = parseFloat(input.value);
        const min = parseFloat(input.min);
        const max = parseFloat(input.max);
        
        if (isNaN(val)) val = min;
        if (val < min) val = min;
        if (val > max) val = max;

        slider.value = String(val);
        callback();
      };

      const updateFromSlider = () => {
        input.value = slider.value;
        callback();
      };

      input.addEventListener('change', updateFromInput);
      slider.addEventListener('input', updateFromSlider);
    };

    setupSync(lumpsumInput, lumpsumSlider, calculateResults);
    setupSync(sipInput, sipSlider, calculateResults);
    setupSync(rateInput, rateSlider, calculateResults);
    setupSync(periodInput, periodSlider, calculateResults);

    // Reset button
    resetBtn?.addEventListener('click', () => {
      lumpsumInput.value = '100000';
      lumpsumSlider.value = '100000';
      sipInput.value = '5000';
      sipSlider.value = '5000';
      rateInput.value = '12';
      rateSlider.value = '12';
      periodInput.value = '10';
      periodSlider.value = '10';
      calculateResults();
    });

    // Handle Results Copy Event from Parent Layout
    window.addEventListener('copy-calculator-results', () => {
      const resultsText = `
FinCalcLab.com - Lumpsum vs SIP Comparison Results:
----------------------------------------------
Time Period: ${periodInput.value} Years
Expected Return: ${rateInput.value}% p.a.

1. Lumpsum Investment:
- Total Invested: ${document.getElementById('lumpsum-invested')?.textContent || ''}
- Est. Returns: ${document.getElementById('lumpsum-gains')?.textContent || ''}
- Future Value: ${document.getElementById('lumpsum-value')?.textContent || ''}

2. Systematic Investment Plan (SIP):
- Total Invested: ${document.getElementById('sip-invested')?.textContent || ''}
- Est. Returns: ${document.getElementById('sip-gains')?.textContent || ''}
- Future Value: ${document.getElementById('sip-value')?.textContent || ''}

Recommendation:
${document.getElementById('sip-recommendation')?.textContent?.trim() || ''}
----------------------------------------------
Calculate more at https://fincalclab.com
      `.trim();

      navigator.clipboard.writeText(resultsText).then(() => {
        window.dispatchEvent(new CustomEvent('calculator-copied-success'));
      });
    });

    // Initial Calculate
    calculateResults();
  }

  // Load handler
  document.addEventListener('DOMContentLoaded', initSipCalculator);
  document.addEventListener('astro:after-swap', initSipCalculator);
</script>

<style>
  /* Inputs wrapper styling */
  .calc-inputs-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .input-label-row label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  /* Currency, Percent & Year Wrapper inputs */
  .input-symbol-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 10px;
    width: 130px;
    height: 38px;
    transition: border-color var(--transition-fast);
  }

  .input-symbol-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .currency-symbol {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-right: 4px;
  }

  .input-symbol-wrapper input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-base);
    text-align: right;
    outline: none;
  }

  .input-symbol-wrapper input::-webkit-outer-spin-button,
  .input-symbol-wrapper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Percent & Years indicator adjustments */
  .percent-wrapper input, .years-wrapper input {
    text-align: left;
  }
  .percent-symbol, .years-symbol {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-left: 4px;
  }

  /* Slider Styling */
  .slider-range {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    outline: none;
    margin: 6px 0;
    cursor: pointer;
  }

  .slider-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--color-bg-surface);
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    transition: transform var(--transition-fast), background var(--transition-fast);
  }

  .slider-range::-webkit-slider-thumb:hover {
    transform: scale(1.15);
    background: var(--color-primary-hover);
  }

  .slider-ticks {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .input-row-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .inputs-actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  /* Results styling */
  .calc-results-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .results-heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0;
    border: none;
    padding: 0;
    margin-top: 0;
  }

  .comparison-cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .comparison-card {
    border: 1px solid var(--color-border);

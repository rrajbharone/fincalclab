---
import CalculatorLayout from './CalculatorLayout.astro';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
---

<CalculatorLayout
  title="Expense Ratio Calculator"
  description="Calculate the true cost of mutual fund and ETF expense ratios over time. See how small differences in management fees create massive fee drag, eroding hundreds of thousands of dollars from your net wealth."
  category="Savings"
>
  <!-- Inputs Section -->
  <div slot="inputs" class="calc-inputs-wrapper" id="expense-ratio-calculator">
    
    <!-- Step 1: Currency & Portfolio Profile -->
    <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-3);">1. Investment Portfolio Profile</h3>
    
    <!-- Currency Selector -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="er-currency-select">Currency</label>
        <select id="er-currency-select" class="currency-select" aria-label="Select Currency">
          <option value="USD" selected>USD ($) - US Dollar</option>
          <option value="EUR">EUR (€) - Euro</option>
          <option value="GBP">GBP (£) - British Pound</option>
          <option value="INR">INR (₹) - Indian Rupee</option>
          <option value="JPY">JPY (¥) - Japanese Yen</option>
          <option value="AUD">AUD (A$) - Australian Dollar</option>
          <option value="CAD">CAD (C$) - Canadian Dollar</option>
          <option value="SGD">SGD (S$) - Singapore Dollar</option>
          <option value="CHF">CHF (CHF) - Swiss Franc</option>
        </select>
      </div>
    </div>

    <!-- Initial Investment -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="er-initial-input">Initial Investment Balance</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="er-initial-input" min="1000" step="2500" value="50000" aria-label="Initial Investment Balance" />
        </div>
      </div>
      <input type="range" id="er-initial-slider" min="1000" max="250000" step="2500" value="50000" class="slider-range" aria-label="Initial Investment Slider" />
    </div>

    <!-- Monthly Contribution -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="er-monthly-input">Monthly Contribution</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="er-monthly-input" min="0" step="100" value="500" aria-label="Monthly Contribution" />
        </div>
      </div>
      <input type="range" id="er-monthly-slider" min="0" max="5000" step="100" value="500" class="slider-range" aria-label="Monthly Contribution Slider" />
    </div>

    <!-- Investment Horizon -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="er-years-input">Investment Horizon (Years)</label>
        <div class="input-symbol-wrapper">
          <input type="number" id="er-years-input" min="1" max="50" step="1" value="25" aria-label="Investment Horizon Years" style="text-align: left;" />
          <span class="percent-symbol">yrs</span>
        </div>
      </div>
      <input type="range" id="er-years-slider" min="1" max="40" step="1" value="25" class="slider-range" aria-label="Years Slider" />
    </div>

    <!-- Expected Gross Annual Return -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="er-gross-return-input">Expected Gross Annual Return</label>
        <div class="input-symbol-wrapper">
          <input type="number" id="er-gross-return-input" min="1.0" max="20.0" step="0.5" value="8.0" aria-label="Expected Gross Annual Return" style="text-align: left;" />
          <span class="percent-symbol">%</span>
        </div>
      </div>
      <input type="range" id="er-gross-return-slider" min="3.0" max="15.0" step="0.5" value="8.0" class="slider-range" aria-label="Gross Return Slider" />
    </div>

    <!-- Step 2: Fund Expense Ratio Comparison -->
    <div style="margin-top: var(--space-5);">
      <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-4);">2. Fund Expense Ratio Comparison</h3>
      
      <!-- Fund A Expense Ratio -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="er-funda-er-input">Fund A Expense Ratio (Low Cost, e.g. Index)</label>
          <div class="input-symbol-wrapper">
            <input type="number" id="er-funda-er-input" min="0.00" max="3.00" step="0.01" value="0.04" aria-label="Fund A Expense Ratio" style="text-align: left;" />
            <span class="percent-symbol">%</span>
          </div>
        </div>
        <input type="range" id="er-funda-er-slider" min="0.00" max="2.00" step="0.01" value="0.04" class="slider-range" aria-label="Fund A ER Slider" />
      </div>

      <!-- Fund B Expense Ratio -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="er-fundb-er-input">Fund B Expense Ratio (High Cost, e.g. Active)</label>
          <div class="input-symbol-wrapper">
            <input type="number" id="er-fundb-er-input" min="0.00" max="4.00" step="0.05" value="0.85" aria-label="Fund B Expense Ratio" style="text-align: left;" />
            <span class="percent-symbol">%</span>
          </div>
        </div>
        <input type="range" id="er-fundb-er-slider" min="0.05" max="3.00" step="0.05" value="0.85" class="slider-range" aria-label="Fund B ER Slider" />
      </div>
    </div>

    <!-- Reset Trigger -->
    <div class="inputs-actions" style="margin-top: var(--space-6);">
      <Button id="er-reset" variant="outline" size="sm" style="width: 100%;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
        Reset Calculator Inputs
      </Button>
    </div>
  </div>

  <!-- Results Section -->
  <div slot="results" class="calc-results-wrapper">
    <h3 class="results-heading">Fee Drag & Wealth Impact Summary</h3>

    <!-- Core Payout Displays -->
    <div class="net-value-container" style="display: flex; gap: var(--space-4); margin-bottom: var(--space-5);">
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-danger);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Total Wealth Lost to Fees</span>
        <div id="res-er-lost-wealth" style="font-size: 1.75rem; font-weight: 800; color: var(--color-danger); margin-top: 4px;">-$131,911.00</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-er-lost-pct">15.76% of total wealth erased</span>
      </div>
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-success);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Fund A Ending Balance</span>
        <div id="res-er-funda-bal" style="font-size: 1.75rem; font-weight: 800; color: var(--color-success); margin-top: 4px;">$837,231.00</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-er-fundb-bal">Fund B Balance: $705,320.00</span>
      </div>
    </div>

    <!-- Optimization Verdict -->
    <div style="margin-bottom: var(--space-6);">
      <Card elevation="sm" id="er-verdict-card" style="border-left: 4px solid var(--color-danger); padding: var(--space-4) var(--space-5); background: var(--color-bg-base);">
        <span style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted);">Fee Drag Diagnosis</span>
        <p id="res-er-verdict-text" style="margin: 4px 0 0 0; font-size: 0.875rem; line-height: 1.5; color: var(--color-text-muted);">
          A <strong>0.81% fee gap</strong> between Fund A (0.04%) and Fund B (0.85%) erodes <strong>$131,911</strong> from your wealth over 25 years.
        </p>
      </Card>
    </div>

    <!-- Key Metrics Grid -->
    <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: var(--space-3);">Expense Ratio Economics Breakdown</h4>
    <div class="results-grid er-metrics-grid">
      <div class="result-tile">
        <span class="tile-label">Fund A Net Return</span>
        <div class="tile-value" id="tile-er-funda-net" style="color: var(--color-success);">7.96%/yr</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-er-funda-desc">8.0% gross - 0.04% ER</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Fund B Net Return</span>
        <div class="tile-value" id="tile-er-fundb-net" style="color: var(--color-warning);">7.15%/yr</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-er-fundb-desc">8.0% gross - 0.85% ER</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Expense Gap Drag</span>
        <div class="tile-value" id="tile-er-gap" style="color: var(--color-danger);">0.81%/yr</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);">Annual management fee gap</span>
      </div>
    </div>
  </div>
</CalculatorLayout>

<script>
  function initErCalculator() {
    // Select elements
    const currencySelect = document.getElementById('er-currency-select') as HTMLSelectElement;

    const initialInput = document.getElementById('er-initial-input') as HTMLInputElement;
    const initialSlider = document.getElementById('er-initial-slider') as HTMLInputElement;
    const monthlyInput = document.getElementById('er-monthly-input') as HTMLInputElement;
    const monthlySlider = document.getElementById('er-monthly-slider') as HTMLInputElement;
    const yearsInput = document.getElementById('er-years-input') as HTMLInputElement;
    const yearsSlider = document.getElementById('er-years-slider') as HTMLInputElement;
    const grossReturnInput = document.getElementById('er-gross-return-input') as HTMLInputElement;
    const grossReturnSlider = document.getElementById('er-gross-return-slider') as HTMLInputElement;

    const fundAErInput = document.getElementById('er-funda-er-input') as HTMLInputElement;
    const fundAErSlider = document.getElementById('er-funda-er-slider') as HTMLInputElement;
    const fundBErInput = document.getElementById('er-fundb-er-input') as HTMLInputElement;
    const fundBErSlider = document.getElementById('er-fundb-er-slider') as HTMLInputElement;

    if (!initialInput || !currencySelect || !fundAErInput || !fundBErInput) return;

    // Slider bindings
    function bindSlider(input: HTMLInputElement, slider: HTMLInputElement) {
      if (!input || !slider) return;
      input.addEventListener('input', () => {
        slider.value = input.value;
        calculateAll();
      });
      slider.addEventListener('input', () => {
        input.value = slider.value;
        calculateAll();
      });
    }

    bindSlider(initialInput, initialSlider);
    bindSlider(monthlyInput, monthlySlider);
    bindSlider(yearsInput, yearsSlider);
    bindSlider(grossReturnInput, grossReturnSlider);
    bindSlider(fundAErInput, fundAErSlider);
    bindSlider(fundBErInput, fundBErSlider);

    // Currency updates
    currencySelect.addEventListener('change', () => {
      const symbol = getCurrencySymbol(currencySelect.value);
      document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = symbol);
      calculateAll();
    });

    function getCurrencySymbol(curr: string) {
      switch (curr) {
        case 'EUR': return '€';
        case 'GBP': return '£';
        case 'INR': return '₹';
        case 'JPY': return '¥';
        case 'AUD': return 'A$';
        case 'CAD': return 'C$';
        case 'SGD': return 'S$';
        case 'CHF': return 'CHF';
        default: return '$';
      }
    }

    // Reset button
    const resetBtn = document.getElementById('er-reset');
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        initialInput.value = '50000';
        initialSlider.value = '50000';
        monthlyInput.value = '500';
        monthlySlider.value = '500';
        yearsInput.value = '25';
        yearsSlider.value = '25';
        grossReturnInput.value = '8.0';
        grossReturnSlider.value = '8.0';

        fundAErInput.value = '0.04';
        fundAErSlider.value = '0.04';
        fundBErInput.value = '0.85';
        fundBErSlider.value = '0.85';

        currencySelect.value = 'USD';
        document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = '$');
        calculateAll();
      });
    }

    function formatCurrency(val: number) {
      const symbol = getCurrencySymbol(currencySelect.value);
      return symbol + val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    // Solve Compounded Future Value with Monthly Deposits
    function calculateFV(P0: number, PMT: number, annualRatePct: number, years: number): number {
      const months = years * 12;
      const monthlyRate = (annualRatePct / 100) / 12;

      if (monthlyRate <= 0) {
        return P0 + PMT * months;
      }

      const fvPrincipal = P0 * Math.pow(1 + monthlyRate, months);
      const fvAnnuity = PMT * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);
      return fvPrincipal + fvAnnuity;
    }

    function calculateAll() {
      // Inputs variables
      const P0 = parseFloat(initialInput.value) || 0;
      const PMT = parseFloat(monthlyInput.value) || 0;
      const Y = parseFloat(yearsInput.value) || 0;
      const grossReturn = parseFloat(grossReturnInput.value) || 8.0;

      const erA = parseFloat(fundAErInput.value) || 0;
      const erB = parseFloat(fundBErInput.value) || 0;

      // Net Return Rates
      const netReturnA = Math.max(0, grossReturn - erA);
      const netReturnB = Math.max(0, grossReturn - erB);

      // Future Values
      const fvA = calculateFV(P0, PMT, netReturnA, Y);
      const fvB = calculateFV(P0, PMT, netReturnB, Y);

      // Fee Drag Metrics
      const lostWealth = Math.max(0, fvA - fvB);
      const lostPct = fvA > 0 ? (lostWealth / fvA) * 100 : 0;
      const erGap = Math.abs(erB - erA);

      // DOM Updates
      const resLostWealth = document.getElementById('res-er-lost-wealth');
      const resFundABal = document.getElementById('res-er-funda-bal');
      const lblLostPct = document.getElementById('lbl-er-lost-pct');
      const lblFundBBal = document.getElementById('lbl-er-fundb-bal');

      if (resLostWealth) resLostWealth.textContent = '-' + formatCurrency(lostWealth);
      if (resFundABal) resFundABal.textContent = formatCurrency(fvA);
      if (lblLostPct) lblLostPct.textContent = `${lostPct.toFixed(2)}% of total potential wealth erased`;
      if (lblFundBBal) lblFundBBal.textContent = `Fund B Balance: ${formatCurrency(fvB)}`;

      // Verdict card and text
      const verdictText = document.getElementById('res-er-verdict-text');
      if (verdictText) {
        const symbol = getCurrencySymbol(currencySelect.value);
        verdictText.innerHTML = `Over <strong>${Y} years</strong>, a <strong>${erGap.toFixed(2)}% expense ratio gap</strong> between Fund A (${erA.toFixed(2)}%) and Fund B (${erB.toFixed(2)}%) erodes <strong>${formatCurrency(lostWealth)}</strong> from your portfolio wealth (a <strong>${lostPct.toFixed(2)}% fee drag loss</strong>). Fund A grows to <strong>${formatCurrency(fvA)}</strong> vs. Fund B's <strong>${formatCurrency(fvB)}</strong>.`;
      }

      // Details Tiles Updates
      const tileFundANet = document.getElementById('tile-er-funda-net');
      const lblFundADesc = document.getElementById('lbl-er-funda-desc');
      const tileFundBNet = document.getElementById('tile-er-fundb-net');
      const lblFundBDesc = document.getElementById('lbl-er-fundb-desc');
      const tileGap = document.getElementById('tile-er-gap');

      if (tileFundANet) tileFundANet.textContent = netReturnA.toFixed(2) + '%/yr';
      if (lblFundADesc) lblFundADesc.textContent = `${grossReturn}% gross - ${erA}% ER`;

      if (tileFundBNet) tileFundBNet.textContent = netReturnB.toFixed(2) + '%/yr';
      if (lblFundBDesc) lblFundBDesc.textContent = `${grossReturn}% gross - ${erB}% ER`;

      if (tileGap) tileGap.textContent = erGap.toFixed(2) + '%/yr';
    }

    // Trigger initial calculation
    calculateAll();

    // Clipboard copy results handler
    window.addEventListener('copy-calculator-results', () => {
      const text = `Expense Ratio Fee Drag Analysis:\n` +
                   `Initial Portfolio: ${initialInput.value} | Monthly Deposit: ${monthlyInput.value}/mo | Horizon: ${yearsInput.value} yrs\n` +
                   `Gross Return: ${grossReturnInput.value}% | Fund A ER: ${fundAErInput.value}% | Fund B ER: ${fundBErInput.value}%\n` +
                   `Fund A Ending Balance: ${document.getElementById('res-er-funda-bal')?.textContent}\n` +
                   `Fund B Ending Balance: ${document.getElementById('lbl-er-fundb-bal')?.textContent}\n` +
                   `Total Wealth Lost to Fees: ${document.getElementById('res-er-lost-wealth')?.textContent} (${document.getElementById('lbl-er-lost-pct')?.textContent})\n` +
                   `Diagnosis: ${document.getElementById('res-er-verdict-text')?.textContent}`;
      
      navigator.clipboard.writeText(text).then(() => {
        window.dispatchEvent(new CustomEvent('calculator-copied-success'));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initErCalculator);
  document.addEventListener('astro:after-swap', initErCalculator);
</script>

<style>
  .calc-inputs-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .input-label-row label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  /* Input symbol wrapper */
  .input-symbol-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 10px;
    width: 145px;
    height: 38px;
    transition: border-color var(--transition-fast);
  }

  .input-symbol-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .currency-symbol {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-right: 4px;
  }

  .input-symbol-wrapper input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-base);
    text-align: right;
    outline: none;
  }

  .input-symbol-wrapper input::-webkit-outer-spin-button,
  .input-symbol-wrapper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .percent-symbol {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-left: 4px;
    white-space: nowrap;
  }

  /* Currency select menu */
  .currency-select {
    width: 100%;
    max-width: 250px;
    height: 38px;
    padding: 0 10px;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-base);
    outline: none;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .currency-select:focus {
    border-color: var(--color-primary);
  }

  /* Slider range */
  .slider-range {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    outline: none;
    margin: 6px 0;
    cursor: pointer;
  }

  .slider-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--color-bg-surface);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), background-color var(--transition-fast);
  }

  .slider-range::-webkit-slider-thumb:hover {
    transform: scale(1.1);
    background: var(--color-primary-hover);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .result-tile {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tile-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .tile-value {
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .net-value-container {
      flex-direction: column;
    }
  }

  @media (max-width: 420px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 500px) {
    .input-label-row {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-2);
    }

    .input-symbol-wrapper {
      width: 100% !important;
      max-width: 100% !important;
    }

    .currency-select {
      max-width: 100% !important;
    }
  }
</style>

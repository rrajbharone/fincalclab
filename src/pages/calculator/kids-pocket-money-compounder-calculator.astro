---
import Layout from '../../layouts/Layout.astro';
import KidsCalculator from '../../components/calculator/KidsCalculator.astro';
import Accordion from '../../components/ui/Accordion.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';

const faqs = [
  {
    question: "How does the Kids' Pocket Money Compounder work?",
    answer: "You input your child's weekly or monthly allowance, an annual percentage increase (their yearly 'raise'), and an expected interest return rate. The calculator simulates saving those contributions over time and compounding them, showing how much interest builds up."
  },
  {
    question: "What is an annual raise in allowance?",
    answer: "As kids grow, their financial responsibilities and chore workloads often increase, so parents often give them a 'raise' in their allowance. The calculator increases the allowance contribution by your specified annual raise percentage at the start of each new year."
  },
  {
    question: "Where can children invest their savings to get 8% interest?",
    answer: "Traditional kid savings bank accounts pay very low interest (1-3%). To achieve 6-10% interest growth, parents can open a custodial brokerage account (like a UTMA/UGMA in the US) or invest in broad-market index funds (which track the S&P 500 or global indices) under a parent's name."
  },
  {
    question: "Why should I teach my child about compounding early?",
    answer: "Time is compound interest's greatest ally. A child who learns to save and invest at age 10 has decades of compounding advantage over someone starting in their 20s or 30s. Even tiny savings like $5/week build habits that lead to life-long financial safety."
  }
];
---

<Layout
  title="Kids' Pocket Money Compounder Calculator"
  description="Teach your kids about compound interest by simulating allowance savings. See how pocket money with annual raises grows when invested."
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Calculators', item: '/all-calculators' },
    { name: 'Kids Compounder', item: '/calculator/kids-pocket-money-compounder-calculator' }
  ]}
  faqs={faqs}
>
  <KidsCalculator />

  <!-- Educational Explanations -->
  <div class="calculator-extra-seo-content container" style="max-width: 1040px; margin-top: var(--space-8);">
    <!-- Compounding logic -->
    <section class="seo-section">
      <h2>Understanding the Compounding Math</h2>
      <p>Saving allowance without compounding means your money grows in a straight line (addition). When you compound it, your money grows in a curved line (multiplication), because you earn interest on top of previous interest!</p>
      
      <div class="formula-box-grid">
        <Card elevation="sm" class="formula-card" style="grid-column: span 2;">
          <h3>The Growing Annuity Compounding Logic</h3>
          <p>Since the allowance increases annually, we simulate the cashflow month-by-month or week-by-week. The mathematical model works as follows:</p>
          <div class="math-expr" set:html={`\\[V_{n} = (V_{n-1} + C_{t}) \\times (1 + i)\\]`} />
          <ul class="formula-legend" set:html={`
            <li><strong>\\(V_n\\):</strong> Value at the end of the current period</li>
            <li><strong>\\(V_{n-1}\\):</strong> Value from the previous period</li>
            <li><strong>\\(C_t\\):</strong> Current allowance deposit (which increases by the Raise % at the start of each year)</li>
            <li><strong>\\(i\\):</strong> Interest rate per compounding period (Annual rate divided by 52 weeks or 12 months)</li>
          `} />
        </Card>
      </div>
    </section>

    <!-- Why use this tool -->
    <section class="seo-section">
      <h2>How Parents Can Use This Tool to Teach Financial Literacy</h2>
      <p>Here are three practical exercises parents can run with their children using this compounder:</p>
      <ul class="spaced-list">
        <li>
          <strong>The Birthday Raise Lesson:</strong> Set the allowance to $5/week and the annual raise to 10%. Show them how their savings speed up as they grow older and get birthday promotions.
        </li>
        <li>
          <strong>The Bank vs Index Fund Test:</strong> Set the interest rate to 2% (typical bank account) and then to 9% (average index fund). Toggle between the two to show them how investing in index funds produces much larger wealth.
        </li>
        <li>
          <strong>The 'Cost of Soda' Comparison:</strong> Show them that saving the cost of one weekly soda ($3) in an account yielding 8% turns into over $2,000 in 10 years.
        </li>
      </ul>
    </section>

    <!-- FAQs Section -->
    <section class="seo-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-accordion-group">
        {faqs.map((faq) => (
          <Accordion title={faq.question}>
            <p style="margin:0;">{faq.answer}</p>
          </Accordion>
        ))}
      </div>
    </section>

    <!-- Call to action related tools -->
    <section class="related-tools-cta">
      <Card elevation="md" class="related-cta-card">
        <div class="cta-inner">
          <div class="cta-text-side">
            <h3>Try Our Other Free Calculators</h3>
            <p>Compare systematic mutual fund investments or estimate your net take-home salary slabs instantly.</p>
          </div>
          <div class="cta-btn-side">
            <Button href="/calculator/lumpsum-vs-sip-calculator" variant="primary">SIP vs Lumpsum</Button>
            <Button href="/calculator/in-hand-salary-calculator" variant="outline">Salary Slabs Tool</Button>
          </div>
        </div>
      </Card>
    </section>
  </div>
</Layout>

<style>
  .seo-section {
    margin-bottom: var(--space-12);
  }

  .seo-section h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
  }

  .spaced-list li {
    margin-bottom: var(--space-4);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .formula-box-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-4);
  }

  .formula-card {
    padding: var(--space-6);
  }

  .formula-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .math-expr {
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    text-align: center;
    font-size: 1.2rem;
    font-weight: 600;
    margin: var(--space-4) 0;
    overflow-x: auto;
  }

  .formula-legend {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0 0;
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .formula-legend li {
    margin-bottom: 0;
  }

  .faq-accordion-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .related-tools-cta {
    margin-top: var(--space-12);
  }

  .related-cta-card {
    background-color: var(--color-bg-surface);
    border-top: 4px solid var(--color-accent);
  }

  .cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-6);
  }

  .cta-text-side h3 {
    margin: 0 0 6px 0;
  }
  .cta-text-side p {
    margin: 0;
    font-size: 0.95rem;
  }

  .cta-btn-side {
    display: flex;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .cta-inner {
      flex-direction: column;
      text-align: center;
    }
    .cta-btn-side {
      flex-direction: column;
      width: 100%;
    }
    .cta-btn-side a, .cta-btn-side button {
      width: 100%;
    }
  }
</style>

<!-- Load LaTeX Math renderer via CDN dynamically -->
<script is:inline src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

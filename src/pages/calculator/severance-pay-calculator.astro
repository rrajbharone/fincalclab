    font-size: 1.5rem;
    font-weight: 800;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    color: var(--color-text-base);
  }

  .prose h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-top: var(--space-5);
    margin-bottom: var(--space-2);
    color: var(--color-text-base);
  }

  .prose p {
    margin-bottom: var(--space-4);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .prose ul, .prose ol {
    margin-bottom: var(--space-4);

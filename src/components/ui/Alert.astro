---
interface Props {
  variant?: 'info' | 'success' | 'warning' | 'error';
  title?: string;
  class?: string;
}

const {
  variant = 'info',
  title,
  class: className = '',
} = Astro.props;

const icons = {
  info: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>`,
  success: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`,
  warning: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>`,
  error: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="15" y2="15"></line><line x1="15" y1="9" x2="9" y2="15"></line></svg>`
};
---

<div class={`alert alert-${variant} ${className}`} role="alert">
  <div class="alert-icon" set:html={icons[variant]} />
  <div class="alert-body">
    {title && <h5 class="alert-title">{title}</h5>}
    <div class="alert-content">
      <slot />
    </div>
  </div>
</div>

<style>
  .alert {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    margin-bottom: var(--space-4);
  }

  .alert-icon {
    display: flex;
    align-items: flex-start;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .alert-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .alert-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .alert-content :global(p) {
    margin: 0;
    font-size: 0.9rem;
    color: inherit;
  }

  /* Variant styles */
  .alert-info {
    background-color: rgba(37, 99, 235, 0.05);
    border-color: rgba(37, 99, 235, 0.2);
    color: var(--color-primary);
  }
  .alert-info .alert-icon { color: var(--color-primary); }
  .alert-info .alert-title { color: var(--color-primary); }
  .alert-info .alert-content { color: var(--color-text-muted); }

  .alert-success {
    background-color: rgba(16, 185, 129, 0.05);
    border-color: rgba(16, 185, 129, 0.2);
    color: #065f46;
  }
  :global(html.dark) .alert-success { color: #34d399; }
  .alert-success .alert-icon { color: var(--color-success); }
  .alert-success .alert-title { color: #065f46; }
  :global(html.dark) .alert-success .alert-title { color: #34d399; }
  .alert-success .alert-content { color: var(--color-text-muted); }

  .alert-warning {
    background-color: rgba(245, 158, 11, 0.05);
    border-color: rgba(245, 158, 11, 0.2);
    color: #92400e;
  }
  :global(html.dark) .alert-warning { color: #fbbf24; }
  .alert-warning .alert-icon { color: var(--color-warning); }
  .alert-warning .alert-title { color: #92400e; }
  :global(html.dark) .alert-warning .alert-title { color: #fbbf24; }
  .alert-warning .alert-content { color: var(--color-text-muted); }

  .alert-error {
    background-color: rgba(239, 68, 68, 0.05);
    border-color: rgba(239, 68, 68, 0.2);
    color: #991b1b;
  }
  :global(html.dark) .alert-error { color: #fca5a5; }
  .alert-error .alert-icon { color: var(--color-error); }
  .alert-error .alert-title { color: #991b1b; }
  :global(html.dark) .alert-error .alert-title { color: #fca5a5; }
  .alert-error .alert-content { color: var(--color-text-muted); }
</style>

---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-top">
    <!-- Brand column -->
    <div class="footer-col brand-col">
      <a href="/" class="footer-logo" aria-label="FinCalcLab Homepage">
        <div class="logo-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="1" x2="12" y2="23"></line>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
          </svg>
        </div>
        <span class="logo-text">FinCalc<span class="logo-accent">Lab</span></span>
      </a>
      <p class="brand-desc">
        Smart Financial Calculators for Better Money Decisions. Fast, secure, privacy-focused, and 100% free forever.
      </p>
      <div class="social-links">
        <a href="https://www.facebook.com/profile.php?id=61589935937085" class="social-link" aria-label="Follow us on Facebook" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="https://x.com/FinCalcLab" class="social-link" aria-label="Follow us on Twitter/X" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
        </a>
        <a href="https://www.instagram.com/fincalclab/" class="social-link" aria-label="Follow us on Instagram" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
      </div>
    </div>

    <!-- Navigation Columns -->
    <div class="footer-col links-col">
      <h3 class="col-title">Calculators</h3>
      <ul class="footer-links">
        <li><a href="/calculator/lumpsum-vs-sip-calculator">SIP vs Lumpsum</a></li>
        <li><a href="/calculator/kids-pocket-money-compounder-calculator">Kids Pocket Compounder</a></li>
        <li><a href="/calculator/in-hand-salary-calculator">In-Hand Salary Calculator</a></li>
      </ul>
    </div>

    <div class="footer-col links-col">
      <h3 class="col-title">Resources</h3>
      <ul class="footer-links">
        <li><a href="/blog">Articles & Guides</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/contact">Support & Contact</a></li>
      </ul>
    </div>

    <div class="footer-col links-col">
      <h3 class="col-title">Legal</h3>
      <ul class="footer-links">
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms of Service</a></li>
        <li><a href="/disclaimer">Disclaimer</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-container">
      <p class="copyright-text">
        &copy; {currentYear} FinCalcLab. All rights reserved. Designed for informational and educational purposes only.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-surface);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
    padding-top: var(--space-12);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr repeat(3, 1fr);
    gap: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Brand Column */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-base);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    background-color: rgba(37, 99, 235, 0.1);
    padding: 4px;
    border-radius: var(--radius-md);
  }

  .logo-accent {
    color: var(--color-primary);
  }

  .brand-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 320px;
  }

  .social-links {
    display: flex;
    gap: var(--space-3);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-light);
    border: 1px solid var(--color-border);
    padding: 8px;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background-color: rgba(37, 99, 235, 0.05);
    transform: translateY(-2px);
  }

  /* Link columns */
  .col-title {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-base);
    margin-bottom: 0;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-links a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: var(--space-6) 0;
    background-color: var(--color-bg-base);
  }

  .bottom-container {
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .copyright-text {
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin: 0;
  }

  /* Responsive styling */
  @media (max-width: 1024px) {
    .footer-top {
      grid-template-columns: 1.5fr repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding-bottom: var(--space-8);
    }

    .footer-col {
      align-items: center;
      text-align: center;
    }

    .footer-logo {
      justify-content: center;
    }

    .brand-desc {
      max-width: 100%;
    }

    .social-links {
      justify-content: center;
    }

    .bottom-container {
      flex-direction: column;
      text-align: center;
      gap: var(--space-2);
    }
  }
</style>

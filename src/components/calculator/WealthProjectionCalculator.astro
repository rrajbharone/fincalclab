---
import CalculatorLayout from './CalculatorLayout.astro';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
---

<CalculatorLayout
  title="Wealth Projection Calculator"
  description="Project the compound growth of your investments over time. Compare raw nominal future wealth against inflation-adjusted real purchasing power, and see how savings rate and return rate build wealth."
  category="Savings"
>
  <!-- Inputs Section -->
  <div slot="inputs" class="calc-inputs-wrapper" id="wealth-projection-calculator">
    
    <!-- Step 1: Currency & Starting Assets -->
    <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-3);">1. Capital & Savings Rates</h3>
    
    <!-- Currency Selector -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="wp-currency-select">Currency</label>
        <select id="wp-currency-select" class="currency-select" aria-label="Select Currency">
          <option value="USD" selected>USD ($) - US Dollar</option>
          <option value="EUR">EUR (€) - Euro</option>
          <option value="GBP">GBP (£) - British Pound</option>
          <option value="INR">INR (₹) - Indian Rupee</option>
          <option value="JPY">JPY (¥) - Japanese Yen</option>
          <option value="AUD">AUD (A$) - Australian Dollar</option>
          <option value="CAD">CAD (C$) - Canadian Dollar</option>
          <option value="SGD">SGD (S$) - Singapore Dollar</option>
          <option value="CHF">CHF (CHF) - Swiss Franc</option>
        </select>
      </div>
    </div>

    <!-- Starting Balance -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="wp-start-input">Current Invested Assets (Starting Balance)</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="wp-start-input" min="0" step="5000" value="100000" aria-label="Starting Balance" />
        </div>
      </div>
      <input type="range" id="wp-start-slider" min="0" max="1000000" step="10000" value="100000" class="slider-range" aria-label="Starting Balance Slider" />
    </div>

    <!-- Monthly Contribution -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="wp-monthly-input">Monthly Savings Deposit</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="wp-monthly-input" min="0" step="100" value="1000" aria-label="Monthly Savings Deposit" />
        </div>
      </div>
      <input type="range" id="wp-monthly-slider" min="0" max="10000" step="100" value="1000" class="slider-range" aria-label="Monthly Deposit Slider" />
    </div>

    <!-- Step 2: Time Horizon & Growth Assumptions -->
    <div style="margin-top: var(--space-5);">
      <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-4);">2. Horizon & Growth Assumptions</h3>
      
      <!-- Horizon Years -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="wp-years-input">Investment Horizon (Years)</label>
          <div class="input-symbol-wrapper">
            <input type="number" id="wp-years-input" min="1" max="50" step="1" value="25" aria-label="Investment Horizon Years" style="text-align: left;" />
            <span class="percent-symbol">yrs</span>
          </div>
        </div>
        <input type="range" id="wp-years-slider" min="1" max="40" step="1" value="25" class="slider-range" aria-label="Horizon Slider" />
      </div>

      <!-- Expected Gross Annual Return -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="wp-return-input">Expected Gross Annual Return</label>
          <div class="input-symbol-wrapper">
            <input type="number" id="wp-return-input" min="1.0" max="20.0" step="0.5" value="8.0" aria-label="Expected Gross Annual Return" style="text-align: left;" />
            <span class="percent-symbol">%</span>
          </div>
        </div>
        <input type="range" id="wp-return-slider" min="3.0" max="15.0" step="0.5" value="8.0" class="slider-range" aria-label="Return Rate Slider" />
      </div>

      <!-- Expected Inflation Rate -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="wp-inflation-input">Expected Annual Inflation Rate</label>
          <div class="input-symbol-wrapper">
            <input type="number" id="wp-inflation-input" min="0.0" max="10.0" step="0.5" value="3.0" aria-label="Expected Annual Inflation Rate" style="text-align: left;" />
            <span class="percent-symbol">%</span>
          </div>
        </div>
        <input type="range" id="wp-inflation-slider" min="0.0" max="8.0" step="0.5" value="3.0" class="slider-range" aria-label="Inflation Rate Slider" />
      </div>
    </div>

    <!-- Reset Trigger -->
    <div class="inputs-actions" style="margin-top: var(--space-6);">
      <Button id="wp-reset" variant="outline" size="sm" style="width: 100%;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
        Reset Calculator Inputs
      </Button>
    </div>
  </div>

  <!-- Results Section -->
  <div slot="results" class="calc-results-wrapper">
    <h3 class="results-heading">Compounding Wealth Forecast</h3>

    <!-- Core Payout Displays -->
    <div class="net-value-container" style="display: flex; gap: var(--space-4); margin-bottom: var(--space-5);">
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-success);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Nominal Future Wealth</span>
        <div id="res-wp-nominal" style="font-size: 1.75rem; font-weight: 800; color: var(--color-success); margin-top: 4px;">$1,685,044.52</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-wp-real">Real Value: $902,255.45</span>
      </div>
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-primary);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Interest Earned (Nominal)</span>
        <div id="res-wp-interest" style="font-size: 1.75rem; font-weight: 800; color: var(--color-primary); margin-top: 4px;">$1,285,044.52</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-wp-contrib">Total Deposits: $400,000.00</span>
      </div>
    </div>

    <!-- Optimization Verdict -->
    <div style="margin-bottom: var(--space-6);">
      <Card elevation="sm" id="wp-verdict-card" style="border-left: 4px solid var(--color-success); padding: var(--space-4) var(--space-5); background: var(--color-bg-base);">
        <span style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted);">Compounding Growth Diagnosis</span>
        <p id="res-wp-verdict-text" style="margin: 4px 0 0 0; font-size: 0.875rem; line-height: 1.5; color: var(--color-text-muted);">
          Starting with <strong>$100,000</strong> and saving <strong>$1,000/mo</strong> for 25 years at an 8% return grows your portfolio to <strong>$1,685,044</strong>. Adjusted for inflation, its true purchasing power is <strong>$902,255</strong>.
        </p>
      </Card>
    </div>

    <!-- Key Metrics Grid -->
    <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: var(--space-3);">Wealth Compounding Waterfall</h4>
    <div class="results-grid wp-metrics-grid">
      <div class="result-tile">
        <span class="tile-label">Real Future Value</span>
        <div class="tile-value" id="tile-wp-real-fv" style="color: var(--color-success);">$902,255</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-wp-real-desc">Purchasing power in today's dollars</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Inflation Lost Value</span>
        <div class="tile-value" id="tile-wp-inflation-drag" style="color: var(--color-danger);">$782,789</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);">Erosion over 25 years</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Net Real Return</span>
        <div class="tile-value" id="tile-wp-real-return" style="color: var(--color-primary);">4.85%/yr</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);">Fisher real return rate</span>
      </div>
    </div>
  </div>
</CalculatorLayout>

<script>
  function initWpCalculator() {
    // Select elements
    const currencySelect = document.getElementById('wp-currency-select') as HTMLSelectElement;

    const startInput = document.getElementById('wp-start-input') as HTMLInputElement;
    const startSlider = document.getElementById('wp-start-slider') as HTMLInputElement;
    const monthlyInput = document.getElementById('wp-monthly-input') as HTMLInputElement;
    const monthlySlider = document.getElementById('wp-monthly-slider') as HTMLInputElement;
    const yearsInput = document.getElementById('wp-years-input') as HTMLInputElement;
    const yearsSlider = document.getElementById('wp-years-slider') as HTMLInputElement;
    const returnInput = document.getElementById('wp-return-input') as HTMLInputElement;
    const returnSlider = document.getElementById('wp-return-slider') as HTMLInputElement;
    const inflationInput = document.getElementById('wp-inflation-input') as HTMLInputElement;
    const inflationSlider = document.getElementById('wp-inflation-slider') as HTMLInputElement;

    if (!startInput || !currencySelect || !monthlyInput || !yearsInput) return;

    // Slider bindings
    function bindSlider(input: HTMLInputElement, slider: HTMLInputElement) {
      if (!input || !slider) return;
      input.addEventListener('input', () => {
        slider.value = input.value;
        calculateAll();
      });
      slider.addEventListener('input', () => {
        input.value = slider.value;
        calculateAll();
      });
    }

    bindSlider(startInput, startSlider);
    bindSlider(monthlyInput, monthlySlider);
    bindSlider(yearsInput, yearsSlider);
    bindSlider(returnInput, returnSlider);
    bindSlider(inflationInput, inflationSlider);

    // Currency updates
    currencySelect.addEventListener('change', () => {
      const symbol = getCurrencySymbol(currencySelect.value);
      document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = symbol);
      calculateAll();
    });

    function getCurrencySymbol(curr: string) {
      switch (curr) {
        case 'EUR': return '€';
        case 'GBP': return '£';
        case 'INR': return '₹';
        case 'JPY': return '¥';
        case 'AUD': return 'A$';
        case 'CAD': return 'C$';
        case 'SGD': return 'S$';
        case 'CHF': return 'CHF';
        default: return '$';
      }
    }

    // Reset button
    const resetBtn = document.getElementById('wp-reset');
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        startInput.value = '100000';
        startSlider.value = '100000';
        monthlyInput.value = '1000';
        monthlySlider.value = '1000';
        yearsInput.value = '25';
        yearsSlider.value = '25';
        returnInput.value = '8.0';
        returnSlider.value = '8.0';
        inflationInput.value = '3.0';
        inflationSlider.value = '3.0';

        currencySelect.value = 'USD';
        document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = '$');
        calculateAll();
      });
    }

    function formatCurrency(val: number) {
      const symbol = getCurrencySymbol(currencySelect.value);
      return symbol + val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    // Solve Compounded Future Value with Monthly Deposits
    function calculateFV(P0: number, PMT: number, annualRatePct: number, years: number): number {
      const months = years * 12;
      const monthlyRate = (annualRatePct / 100) / 12;

      if (monthlyRate <= 0) {
        return P0 + PMT * months;
      }

      const fvPrincipal = P0 * Math.pow(1 + monthlyRate, months);
      const fvAnnuity = PMT * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);
      return fvPrincipal + fvAnnuity;
    }

    function calculateAll() {
      // Inputs variables
      const P0 = parseFloat(startInput.value) || 0;
      const PMT = parseFloat(monthlyInput.value) || 0;
      const Y = parseFloat(yearsInput.value) || 0;
      const grossReturn = parseFloat(returnInput.value) || 8.0;
      const inflation = parseFloat(inflationInput.value) || 0;

      // Net Real Return Rate (Fisher Equation)
      const realReturn = ((1 + grossReturn / 100) / (1 + inflation / 100) - 1) * 100;

      // Future Values
      const fvNominal = calculateFV(P0, PMT, grossReturn, Y);
      const fvReal = calculateFV(P0, PMT, realReturn, Y);

      // Compounding Waterfall Math
      const totalContrib = P0 + (PMT * 12 * Y);
      const nominalInterest = Math.max(0, fvNominal - totalContrib);
      const inflationDrag = Math.max(0, fvNominal - fvReal);

      // DOM Updates
      const resNominal = document.getElementById('res-wp-nominal');
      const resInterest = document.getElementById('res-wp-interest');
      const lblReal = document.getElementById('lbl-wp-real');
      const lblContrib = document.getElementById('lbl-wp-contrib');

      if (resNominal) resNominal.textContent = formatCurrency(fvNominal);
      if (resInterest) resInterest.textContent = formatCurrency(nominalInterest);
      if (lblReal) lblReal.textContent = `Real Value (Today's Power): ${formatCurrency(fvReal)}`;
      if (lblContrib) lblContrib.textContent = `Total Deposits: ${formatCurrency(totalContrib)}`;

      // Verdict card and text
      const verdictText = document.getElementById('res-wp-verdict-text');
      if (verdictText) {
        verdictText.innerHTML = `Starting with <strong>${formatCurrency(P0)}</strong> and adding <strong>${formatCurrency(PMT)}/month</strong> over <strong>${Y} years</strong> at an <strong>${grossReturn.toFixed(1)}% gross return</strong> grows your portfolio to <strong>${formatCurrency(fvNominal)}</strong> in nominal wealth. Adjusted for <strong>${inflation.toFixed(1)}% inflation</strong> (leaving a <strong>${realReturn.toFixed(2)}% real return</strong>), your portfolio's true purchasing power matches <strong>${formatCurrency(fvReal)}</strong> today, having lost <strong>${formatCurrency(inflationDrag)}</strong> to price inflation.`;
      }

      // Details Tiles Updates
      const tileRealFv = document.getElementById('tile-wp-real-fv');
      const tileInflationDrag = document.getElementById('tile-wp-inflation-drag');
      const tileRealReturn = document.getElementById('tile-wp-real-return');
      const lblRealDesc = document.getElementById('lbl-wp-real-desc');

      if (tileRealFv) tileRealFv.textContent = formatCurrency(fvReal).split('.')[0];
      if (lblRealDesc) lblRealDesc.textContent = `Purchasing power in today's dollars`;

      if (tileInflationDrag) tileInflationDrag.textContent = formatCurrency(inflationDrag).split('.')[0];
      if (tileRealReturn) tileRealReturn.textContent = realReturn.toFixed(2) + '%/yr';
    }

    // Trigger initial calculation
    calculateAll();

    // Clipboard copy results handler
    window.addEventListener('copy-calculator-results', () => {
      const text = `Investment Wealth Compounding Projection:\n` +
                   `Starting Balance: ${startInput.value} | Monthly Deposit: ${monthlyInput.value}/mo | Horizon: ${yearsInput.value} yrs\n` +
                   `Gross Return: ${returnInput.value}% | Inflation: ${inflationInput.value}%\n` +
                   `Nominal Future Wealth: ${document.getElementById('res-wp-nominal')?.textContent} (${document.getElementById('lbl-wp-real')?.textContent})\n` +
                   `Nominal Interest: ${document.getElementById('res-wp-interest')?.textContent} (${document.getElementById('lbl-wp-contrib')?.textContent})\n` +
                   `Inflation Lost Value: ${document.getElementById('tile-wp-inflation-drag')?.textContent}\n` +
                   `Diagnosis: ${document.getElementById('res-wp-verdict-text')?.textContent}`;
      
      navigator.clipboard.writeText(text).then(() => {
        window.dispatchEvent(new CustomEvent('calculator-copied-success'));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initWpCalculator);
  document.addEventListener('astro:after-swap', initWpCalculator);
</script>

<style>
  .calc-inputs-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .input-label-row label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  /* Input symbol wrapper */
  .input-symbol-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 10px;
    width: 145px;
    height: 38px;
    transition: border-color var(--transition-fast);
  }

  .input-symbol-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .currency-symbol {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-right: 4px;
  }

  .input-symbol-wrapper input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-base);
    text-align: right;
    outline: none;
  }

  .input-symbol-wrapper input::-webkit-outer-spin-button,
  .input-symbol-wrapper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .percent-symbol {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-left: 4px;
    white-space: nowrap;
  }

  /* Currency select menu */
  .currency-select {
    width: 100%;
    max-width: 250px;
    height: 38px;
    padding: 0 10px;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-base);
    outline: none;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .currency-select:focus {
    border-color: var(--color-primary);
  }

  /* Slider range */
  .slider-range {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    outline: none;
    margin: 6px 0;
    cursor: pointer;
  }

  .slider-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--color-bg-surface);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), background-color var(--transition-fast);
  }

  .slider-range::-webkit-slider-thumb:hover {
    transform: scale(1.1);
    background: var(--color-primary-hover);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .result-tile {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tile-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .tile-value {
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .net-value-container {
      flex-direction: column;
    }
  }

  @media (max-width: 420px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 500px) {
    .input-label-row {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-2);
    }

    .input-symbol-wrapper {
      width: 100% !important;
      max-width: 100% !important;
    }

    .currency-select {
      max-width: 100% !important;
    }
  }
</style>

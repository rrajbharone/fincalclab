---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
---

<Layout
  title="All Financial Calculators - FinCalcLab"
  description="Explore our suite of free, interactive financial calculators. Calculate SIP returns, compare lumpsum investments, compound pocket money, and estimate take-home salaries."
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Calculators', item: '/all-calculators' }
  ]}
>
  <div class="calculators-directory-page">
    <div class="container">
      <!-- Header Banner -->
      <div class="directory-header text-center">
        <Badge variant="primary">Financial Suite</Badge>
        <h1 class="directory-title">All Financial Calculators</h1>
        <p class="directory-subtitle">Select any tool below to calculate returns, compound savings, estimate taxes, and plan your wealth creation journey.</p>
        
        <!-- Live Search Box -->
        <div class="search-box-wrapper">
          <div class="search-icon-inside">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <input 
            type="text" 
            id="dir-search-input" 
            placeholder="Type to search calculators (e.g., SIP, salary, compound)..." 
            aria-label="Search financial calculators" 
            autocomplete="off"
          />
        </div>
      </div>

      <!-- Calculators Cards List Grid (Sorted Alphabetically A to Z) -->
      <div class="calculators-grid" id="dir-calculators-grid">
        <!-- Barista FIRE Calculator -->
        <div class="calc-card-item" data-keywords="barista fire calculator calculate barista fire semi retirement early retirement nest egg savings discount part time income health insurance safe withdrawal rate">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Savings & Wealth</span>
              <h3 class="calc-card-title">Barista FIRE Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate your shortcut to early retirement. See how working part-time slashes your required nest egg, comparison vs Full FIRE, and timeline.</p>
            <div class="calc-card-action">
              <Button href="/calculator/barista-fire-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Cash Back Calculator -->
        <div class="calc-card-item" data-keywords="cash back calculator calculate cash back rewards credit card bonus cash earn rate annual fee net profit card comparison">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Savings & Wealth</span>
              <h3 class="calc-card-title">Cash Back Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate credit card rewards and net cashback profit. Compare cash back rates, spending categories, welcome bonuses, and annual fees.</p>
            <div class="calc-card-action">
              <Button href="/calculator/cash-back-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Cost of Delay Calculator -->
        <div class="calc-card-item" data-keywords="cost of delay calculator delaying retirement savings compound interest starting early missed gains opportunity cost">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Savings & Wealth</span>
              <h3 class="calc-card-title">Cost of Delay Calculator</h3>
            </div>
            <p class="calc-card-desc">See how much delaying your retirement savings costs you over time. Calculate lost compound growth and the extra monthly savings required.</p>
            <div class="calc-card-action">
              <Button href="/calculator/cost-of-delay-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Debt Avalanche Calculator -->
        <div class="calc-card-item" data-keywords="debt avalanche calculator calculate debt avalanche payoff highest interest rate debt payoff strategy interest saved timeline">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Debt & Credit</span>
              <h3 class="calc-card-title">Debt Avalanche Calculator</h3>
            </div>
            <p class="calc-card-desc">Eliminate debt by targeting your highest interest rates first. Calculate your exact debt-free date, total interest saved, and monthly payoff schedule.</p>
            <div class="calc-card-action">
              <Button href="/calculator/debt-avalanche-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Debt Snowball Calculator -->
        <div class="calc-card-item" data-keywords="debt snowball calculator calculate debt snowball payoff lowest balance debt strategy quick wins psychological momentum timeline">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Debt & Credit</span>
              <h3 class="calc-card-title">Debt Snowball Calculator</h3>
            </div>
            <p class="calc-card-desc">Build momentum by paying off your smallest balances first. Calculate quick wins, debt-free timelines, and total interest paid under the snowball strategy.</p>
            <div class="calc-card-action">
              <Button href="/calculator/debt-snowball-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Discount Percentage Calculator -->
        <div class="calc-card-item" data-keywords="discount percentage calculator calculate discount percentage original price sale price amount saved retail shopping clearance deal">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-accent">Shopping & Savings</span>
              <h3 class="calc-card-title">Discount Percentage Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate exact percentage discounts, final sale prices, and money saved. Reverse calculate original prices or discount percentages instantly.</p>
            <div class="calc-card-action">
              <Button href="/calculator/discount-percentage-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Economic Order Quantity Calculator -->
        <div class="calc-card-item" data-keywords="economic order quantity calculator calculate eoq optimal order quantity holding cost ordering cost total annual inventory cost demand">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-primary">Business & Operations</span>
              <h3 class="calc-card-title">Economic Order Quantity Calculator</h3>
            </div>
            <p class="calc-card-desc">Find the optimal order quantity that minimizes total annual inventory costs. Compute holding costs, ordering costs, and optimal reorder batch sizes.</p>
            <div class="calc-card-action">
              <Button href="/calculator/economic-order-quantity-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Forex Position Size Calculator -->
        <div class="calc-card-item" data-keywords="forex position size calculator calculate forex position size lot size pip value risk percentage account balance stop loss currency pair">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-primary">Trading & Investing</span>
              <h3 class="calc-card-title">Forex Position Size Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate exact lot sizes (Standard, Mini, Micro) for forex trading based on account risk percentage, stop loss pips, and currency pairs.</p>
            <div class="calc-card-action">
              <Button href="/calculator/forex-position-size-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Freelance Hourly Rate Calculator -->
        <div class="calc-card-item" data-keywords="freelance hourly rate target annual income billable hours overhead tax rate minimum hourly rate self employed pricing freelance">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-success">Salary & Freelance</span>
              <h3 class="calc-card-title">Freelance Hourly Rate Calculator</h3>
            </div>
            <p class="calc-card-desc">Determine your minimum billable hourly rate based on desired net income, business overhead, billable hours efficiency, and self-employment taxes.</p>
            <div class="calc-card-action">
              <Button href="/calculator/freelance-hourly-rate-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- In-Hand Salary Calculator -->
        <div class="calc-card-item" data-keywords="salary net in hand income tax slabs budget 2025 India new regime gross ctc HRA deductions pt pf flat rate takehome">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-success">Salary & Tax</span>
              <h3 class="calc-card-title">In-Hand Salary Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate your monthly take-home salary, estimate tax liabilities under the Budget 2025 slabs or custom rates, and analyze deductions.</p>
            <div class="calc-card-action">
              <Button href="/calculator/in-hand-salary-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Inflation Impact Calculator -->
        <div class="calc-card-item" data-keywords="inflation impact purchasing power cost of living future value real purchasing power price inflation erosion consumer price index CPI">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Savings & Inflation</span>
              <h3 class="calc-card-title">Inflation Impact Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate how inflation erodes purchasing power over time and compute the future cost of living or equivalent salary needed to maintain your lifestyle.</p>
            <div class="calc-card-action">
              <Button href="/calculator/inflation-impact-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Inflation Loss Calculator -->
        <div class="calc-card-item" data-keywords="inflation loss calculator calculate inflation loss purchasing power decay erosion Fisher equation real interest rate opportunity cost savings bank interest index fund">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Savings & Wealth</span>
              <h3 class="calc-card-title">Inflation Loss Calculator</h3>
            </div>
            <p class="calc-card-desc">See how inflation erodes cash savings. Calculate real purchasing power, net dollar losses, Fisher real interest rates, and index fund opportunity costs.</p>
            <div class="calc-card-action">
              <Button href="/calculator/inflation-loss-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Inventory Cost Calculator -->
        <div class="calc-card-item" data-keywords="inventory cost holding cost carrying cost storage capital shortage ordering cost business ecommerce logistics inventory">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-primary">Business & Operations</span>
              <h3 class="calc-card-title">Inventory Cost Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate total annual inventory holding, carrying, storage, capital, and ordering costs for e-commerce and retail businesses.</p>
            <div class="calc-card-action">
              <Button href="/calculator/inventory-cost-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Inventory Days Calculator -->
        <div class="calc-card-item" data-keywords="inventory days calculator calculate inventory days outstanding DSI days sales of inventory turnover ratio COGS average inventory cash conversion cycle">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-primary">Business & Operations</span>
              <h3 class="calc-card-title">Inventory Days Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate Days Sales of Inventory (DSI). Compute how fast inventory sells, inventory turnover ratio, working capital efficiency, and carrying costs.</p>
            <div class="calc-card-action">
              <Button href="/calculator/inventory-days-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Kids Pocket Money Compounder -->
        <div class="calc-card-item" data-keywords="kids pocket money allowance savings compound compounder family parenting raise">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-accent">Savings</span>
              <h3 class="calc-card-title">Kids Pocket Money Compounder</h3>
            </div>
            <p class="calc-card-desc">See the magic of compound interest in action! Model pocket money allowances with weekly or monthly payouts and annual step-up raises.</p>
            <div class="calc-card-action">
              <Button href="/calculator/kids-pocket-money-compounder-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Lean FIRE Calculator -->
        <div class="calc-card-item" data-keywords="lean fire calculator calculate lean fire minimalist early retirement nest egg savings discount frugal living safe withdrawal rate">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Savings & Wealth</span>
              <h3 class="calc-card-title">Lean FIRE Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate your minimalist early retirement nest egg. See how frugal living slashes your required portfolio, comparison vs Standard FIRE, and timeline.</p>
            <div class="calc-card-action">
              <Button href="/calculator/lean-fire-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- LTV:CAC Ratio Calculator -->
        <div class="calc-card-item" data-keywords="ltv cac ratio calculator customer lifetime value acquisition cost saas unit economics gross margin payback period churn rate">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-primary">Business & SaaS</span>
              <h3 class="calc-card-title">LTV:CAC Ratio Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate Customer Lifetime Value to Customer Acquisition Cost ratio (LTV:CAC). Compute payback period, gross margin, churn, and SaaS unit economics.</p>
            <div class="calc-card-action">
              <Button href="/calculator/ltv-cac-ratio-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Markup Calculator -->
        <div class="calc-card-item" data-keywords="markup calculator cost price selling price gross margin profit margin markup percentage retail pricing business ecommerce">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-primary">Business & Retail</span>
              <h3 class="calc-card-title">Markup Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate selling prices, markup percentage, and gross profit margin from unit cost. Convert seamlessly between markup percentage and profit margin.</p>
            <div class="calc-card-action">
              <Button href="/calculator/markup-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Nominal Interest Rate Calculator -->
        <div class="calc-card-item" data-keywords="nominal interest rate calculator effective interest rate EAR APY compounding frequency monthly quarterly daily real interest rate inflation">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-warning">Banking & Loans</span>
              <h3 class="calc-card-title">Nominal Interest Rate Calculator</h3>
            </div>
            <p class="calc-card-desc">Convert nominal annual interest rates to Effective Annual Rate (EAR / APY) across compounding frequencies, or adjust for inflation to calculate real interest rates.</p>
            <div class="calc-card-action">
              <Button href="/calculator/nominal-interest-rate-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Overtime Pay Calculator -->
        <div class="calc-card-item" data-keywords="overtime pay calculator calculate overtime pay rate time and a half double time FLSA weekly hours base hourly wage paycheck">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-success">Salary & Tax</span>
              <h3 class="calc-card-title">Overtime Pay Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate overtime earnings under FLSA laws. Compute time-and-a-half (1.5x), double time (2.0x), regular pay, total gross paycheck, and taxes.</p>
            <div class="calc-card-action">
              <Button href="/calculator/overtime-pay-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>

        <!-- Pay Raise Calculator -->
        <div class="calc-card-item" data-keywords="pay raise calculator percent how to calculate pay raise percentage annual pay raise increase back pay federal employee GS locality rating performance merit salary">
          <Card hoverable elevation="md" class="calc-card">
            <div class="calc-card-header">
              <span class="calc-card-badge text-success">Salary & Tax</span>
              <h3 class="calc-card-title">Pay Raise Calculator</h3>
            </div>
            <p class="calc-card-desc">Calculate pay raise percentage, new annual salary, back pay owed, or performance ratings based on a 5-star review scale.</p>
            <div class="calc-card-action">
              <Button href="/calculator/pay-raise-calculator" variant="text" size="sm" class="full-link-btn">
                Launch Calculator
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </Button>
            </div>
          </Card>
        </div>


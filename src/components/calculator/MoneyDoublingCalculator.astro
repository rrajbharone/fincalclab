---
import CalculatorLayout from './CalculatorLayout.astro';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
---

<CalculatorLayout
  title="Money Doubling Calculator"
  description="Calculate how fast your money will double under compounding growth. Compare the Rule of 72 shortcut against exact logarithmic formulas, and see the impact of inflation on your doubling horizon."
  category="Savings"
>
  <!-- Inputs Section -->
  <div slot="inputs" class="calc-inputs-wrapper" id="money-doubling-calculator">
    
    <!-- Step 1: Currency & Principal -->
    <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-3);">1. Capital & Compounding Frequency</h3>
    
    <!-- Currency Selector -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="md-currency-select">Currency</label>
        <select id="md-currency-select" class="currency-select" aria-label="Select Currency">
          <option value="USD" selected>USD ($) - US Dollar</option>
          <option value="EUR">EUR (€) - Euro</option>
          <option value="GBP">GBP (£) - British Pound</option>
          <option value="INR">INR (₹) - Indian Rupee</option>
          <option value="JPY">JPY (¥) - Japanese Yen</option>
          <option value="AUD">AUD (A$) - Australian Dollar</option>
          <option value="CAD">CAD (C$) - Canadian Dollar</option>
          <option value="SGD">SGD (S$) - Singapore Dollar</option>
          <option value="CHF">CHF (CHF) - Swiss Franc</option>
        </select>
      </div>
    </div>

    <!-- Starting Principal -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="md-principal-input">Principal Investment Amount</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="md-principal-input" min="100" step="500" value="10000" aria-label="Principal Investment Amount" />
        </div>
      </div>
      <input type="range" id="md-principal-slider" min="1000" max="250000" step="2500" value="10000" class="slider-range" aria-label="Principal Slider" />
    </div>

    <!-- Compounding Frequency -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="md-freq-select">Compounding Frequency</label>
        <select id="md-freq-select" class="currency-select" aria-label="Select Compounding Frequency" style="max-width: 100%;">
          <option value="annual">Annually (1x / year)</option>
          <option value="quarterly">Quarterly (4x / year)</option>
          <option value="monthly" selected>Monthly (12x / year)</option>
          <option value="daily">Daily (365x / year)</option>
          <option value="continuous">Continuous Compounding</option>
        </select>
      </div>
    </div>

    <!-- Step 2: Growth Rates -->
    <div style="margin-top: var(--space-5);">
      <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-4);">2. Expected Growth & Inflation</h3>
      
      <!-- Expected Return Rate -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="md-return-input">Expected Annual Return Rate</label>
          <div class="input-symbol-wrapper">
            <input type="number" id="md-return-input" min="0.5" max="30.0" step="0.1" value="8.0" aria-label="Expected Annual Return Rate" style="text-align: left;" />
            <span class="percent-symbol">%</span>
          </div>
        </div>
        <input type="range" id="md-return-slider" min="1.0" max="25.0" step="0.1" value="8.0" class="slider-range" aria-label="Return Rate Slider" />
      </div>

      <!-- Expected Inflation Rate -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="md-inflation-input">Expected Annual Inflation Rate</label>
          <div class="input-symbol-wrapper">
            <input type="number" id="md-inflation-input" min="0.0" max="10.0" step="0.5" value="3.0" aria-label="Expected Annual Inflation Rate" style="text-align: left;" />
            <span class="percent-symbol">%</span>
          </div>
        </div>
        <input type="range" id="md-inflation-slider" min="0.0" max="8.0" step="0.5" value="3.0" class="slider-range" aria-label="Inflation Rate Slider" />
      </div>
    </div>

    <!-- Reset Trigger -->
    <div class="inputs-actions" style="margin-top: var(--space-6);">
      <Button id="md-reset" variant="outline" size="sm" style="width: 100%;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
        Reset Calculator Inputs
      </Button>
    </div>
  </div>

  <!-- Results Section -->
  <div slot="results" class="calc-results-wrapper">
    <h3 class="results-heading">Money Doubling Forecast</h3>

    <!-- Core Payout Displays -->
    <div class="net-value-container" style="display: flex; gap: var(--space-4); margin-bottom: var(--space-5);">
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-success);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Nominal Doubling Horizon</span>
        <div id="res-md-nominal-yrs" style="font-size: 1.75rem; font-weight: 800; color: var(--color-success); margin-top: 4px;">8.69 years</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-md-nominal-bal">Nominal Target: $20,000.00</span>
      </div>
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-primary);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Real Doubling Horizon</span>
        <div id="res-md-real-yrs" style="font-size: 1.75rem; font-weight: 800; color: var(--color-primary); margin-top: 4px;">14.31 years</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-md-real-bal">Real Target: $10,000.00 buying power</span>
      </div>
    </div>

    <!-- Optimization Verdict -->
    <div style="margin-bottom: var(--space-6);">
      <Card elevation="sm" id="md-verdict-card" style="border-left: 4px solid var(--color-success); padding: var(--space-4) var(--space-5); background: var(--color-bg-base);">
        <span style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted);">Doubling Crossover Diagnosis</span>
        <p id="res-md-verdict-text" style="margin: 4px 0 0 0; font-size: 0.875rem; line-height: 1.5; color: var(--color-text-muted);">
          Under monthly compounding at <strong>8.0% return</strong>, your money doubles in face value in <strong>8.69 years</strong>. Adjusted for <strong>3.0% inflation</strong>, it takes <strong>14.31 years</strong> to double in actual buying power.
        </p>
      </Card>
    </div>

    <!-- Key Metrics Grid -->
    <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: var(--space-3);">Compounding Milestones</h4>
    <div class="results-grid md-metrics-grid">
      <div class="result-tile">
        <span class="tile-label">Rule of 72 Estimate</span>
        <div class="tile-value" id="tile-md-rule72" style="color: var(--color-success);">9.00 yrs</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);">Standard mental shortcut</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Tripling Horizon (3x)</span>
        <div class="tile-value" id="tile-md-triple" style="color: var(--color-primary);">13.78 yrs</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-md-triple-bal">Target: $30,000</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Quadrupling Horizon (4x)</span>
        <div class="tile-value" id="tile-md-quad" style="color: var(--color-accent);">17.39 yrs</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-md-quad-bal">Target: $40,000</span>
      </div>
    </div>
  </div>
</CalculatorLayout>

<script>
  function initMdCalculator() {
    // Select elements
    const currencySelect = document.getElementById('md-currency-select') as HTMLSelectElement;
    const freqSelect = document.getElementById('md-freq-select') as HTMLSelectElement;

    const principalInput = document.getElementById('md-principal-input') as HTMLInputElement;
    const principalSlider = document.getElementById('md-principal-slider') as HTMLInputElement;
    const returnInput = document.getElementById('md-return-input') as HTMLInputElement;
    const returnSlider = document.getElementById('md-return-slider') as HTMLInputElement;
    const inflationInput = document.getElementById('md-inflation-input') as HTMLInputElement;
    const inflationSlider = document.getElementById('md-inflation-slider') as HTMLInputElement;

    if (!principalInput || !currencySelect || !freqSelect) return;

    // Slider bindings
    function bindSlider(input: HTMLInputElement, slider: HTMLInputElement) {
      if (!input || !slider) return;
      input.addEventListener('input', () => {
        slider.value = input.value;
        calculateAll();
      });
      slider.addEventListener('input', () => {
        input.value = slider.value;
        calculateAll();
      });
    }

    bindSlider(principalInput, principalSlider);
    bindSlider(returnInput, returnSlider);
    bindSlider(inflationInput, inflationSlider);
    freqSelect.addEventListener('change', calculateAll);

    // Currency updates
    currencySelect.addEventListener('change', () => {
      const symbol = getCurrencySymbol(currencySelect.value);
      document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = symbol);
      calculateAll();
    });

    function getCurrencySymbol(curr: string) {
      switch (curr) {
        case 'EUR': return '€';
        case 'GBP': return '£';
        case 'INR': return '₹';
        case 'JPY': return '¥';
        case 'AUD': return 'A$';
        case 'CAD': return 'C$';
        case 'SGD': return 'S$';
        case 'CHF': return 'CHF';
        default: return '$';
      }
    }

    // Reset button
    const resetBtn = document.getElementById('md-reset');
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        principalInput.value = '10000';
        principalSlider.value = '10000';
        returnInput.value = '8.0';
        returnSlider.value = '8.0';
        inflationInput.value = '3.0';
        inflationSlider.value = '3.0';

        freqSelect.value = 'monthly';
        currencySelect.value = 'USD';
        document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = '$');
        calculateAll();
      });
    }

    function formatCurrency(val: number) {
      const symbol = getCurrencySymbol(currencySelect.value);
      return symbol + val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    // Exact Logarithmic Doubling Calculator function
    function solveTimeYears(multiplier: number, ratePct: number, freq: string): number {
      if (ratePct <= 0) return Infinity;
      
      const r = ratePct / 100;
      if (freq === 'continuous') {
        return Math.log(multiplier) / r;
      }

      let n = 1;
      if (freq === 'monthly') n = 12;
      else if (freq === 'quarterly') n = 4;
      else if (freq === 'daily') n = 365;

      const ratePerPeriod = ratePct / (100 * n);
      return Math.log(multiplier) / (n * Math.log(1 + ratePerPeriod));
    }

    function calculateAll() {
      // Inputs variables
      const P0 = parseFloat(principalInput.value) || 0;
      const grossReturn = parseFloat(returnInput.value) || 8.0;
      const inflation = parseFloat(inflationInput.value) || 0;
      const freq = freqSelect.value;

      // Targets
      const nominalDoubleTarget = P0 * 2;
      const nominalTripleTarget = P0 * 3;
      const nominalQuadTarget = P0 * 4;

      // Real Return Rate (Fisher)
      const realReturn = ((1 + grossReturn / 100) / (1 + inflation / 100) - 1) * 100;

      // Doubling Timelines (Nominal vs Real)
      const yrsNominalDouble = solveTimeYears(2, grossReturn, freq);
      const yrsRealDouble = solveTimeYears(2, realReturn, freq);

      const yrsNominalTriple = solveTimeYears(3, grossReturn, freq);
      const yrsNominalQuad = solveTimeYears(4, grossReturn, freq);

      // Rule of 72 Estimate
      const rule72Estimate = grossReturn > 0 ? 72 / grossReturn : Infinity;

      // DOM Updates
      const resNominalYrs = document.getElementById('res-md-nominal-yrs');
      const resRealYrs = document.getElementById('res-md-real-yrs');
      const lblNominalBal = document.getElementById('lbl-md-nominal-bal');
      const lblRealBal = document.getElementById('lbl-md-real-bal');

      if (resNominalYrs) resNominalYrs.textContent = yrsNominalDouble.toFixed(2) + ' years';
      if (resRealYrs) resRealYrs.textContent = yrsRealDouble.toFixed(2) + ' years';
      if (lblNominalBal) lblNominalBal.textContent = `Nominal Target: ${formatCurrency(nominalDoubleTarget)}`;
      if (lblRealBal) lblRealBal.textContent = `Real Target: ${formatCurrency(P0)} in buying power`;

      // Verdict card and text
      const verdictText = document.getElementById('res-md-verdict-text');
      if (verdictText) {
        const freqText = freq === 'continuous' ? 'continuous compounding' : `${freq} compounding`;
        verdictText.innerHTML = `Under ${freqText} at a <strong>${grossReturn.toFixed(1)}% annual return</strong>, your starting capital of <strong>${formatCurrency(P0)}</strong> doubles in raw balance to <strong>${formatCurrency(nominalDoubleTarget)}</strong> in <strong>${yrsNominalDouble.toFixed(2)} years</strong>. Adjusted for <strong>${inflation.toFixed(1)}% inflation</strong> (real return of <strong>${realReturn.toFixed(2)}%</strong>), it takes <strong>${yrsRealDouble.toFixed(2)} years</strong> to double in actual purchasing power.`;
      }

      // Details Tiles Updates
      const tileRule72 = document.getElementById('tile-md-rule72');
      const tileTriple = document.getElementById('tile-md-triple');
      const lblTripleBal = document.getElementById('lbl-md-triple-bal');
      const tileQuad = document.getElementById('tile-md-quad');
      const lblQuadBal = document.getElementById('lbl-md-quad-bal');

      if (tileRule72) tileRule72.textContent = rule72Estimate.toFixed(2) + ' yrs';
      
      if (tileTriple) tileTriple.textContent = yrsNominalTriple.toFixed(2) + ' yrs';
      if (lblTripleBal) lblTripleBal.textContent = `Target: ${formatCurrency(nominalTripleTarget).split('.')[0]}`;

      if (tileQuad) tileQuad.textContent = yrsNominalQuad.toFixed(2) + ' yrs';
      if (lblQuadBal) lblQuadBal.textContent = `Target: ${formatCurrency(nominalQuadTarget).split('.')[0]}`;
    }

    // Trigger initial calculation
    calculateAll();

    // Clipboard copy results handler
    window.addEventListener('copy-calculator-results', () => {
      const text = `Money Doubling Compounding Forecast:\n` +
                   `Principal Investment: ${principalInput.value} | Annual Return: ${returnInput.value}% | Inflation: ${inflationInput.value}%\n` +
                   `Compounding Frequency: ${freqSelect.value}\n` +
                   `Nominal Doubling: ${document.getElementById('res-md-nominal-yrs')?.textContent} (${document.getElementById('lbl-md-nominal-bal')?.textContent})\n` +
                   `Real Doubling: ${document.getElementById('res-md-real-yrs')?.textContent} (${document.getElementById('lbl-md-real-bal')?.textContent})\n` +
                   `Rule of 72 Estimate: ${document.getElementById('tile-md-rule72')?.textContent}\n` +
                   `Nominal Tripling: ${document.getElementById('tile-md-triple')?.textContent} | Nominal Quadrupling: ${document.getElementById('tile-md-quad')?.textContent}\n` +
                   `Diagnosis: ${document.getElementById('res-md-verdict-text')?.textContent}`;
      
      navigator.clipboard.writeText(text).then(() => {
        window.dispatchEvent(new CustomEvent('calculator-copied-success'));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initMdCalculator);
  document.addEventListener('astro:after-swap', initMdCalculator);
</script>

<style>
  .calc-inputs-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .input-label-row label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  /* Input symbol wrapper */
  .input-symbol-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 10px;
    width: 145px;
    height: 38px;
    transition: border-color var(--transition-fast);
  }

  .input-symbol-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .currency-symbol {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-right: 4px;
  }

  .input-symbol-wrapper input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-base);
    text-align: right;
    outline: none;
  }

  .input-symbol-wrapper input::-webkit-outer-spin-button,
  .input-symbol-wrapper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .percent-symbol {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-left: 4px;
    white-space: nowrap;
  }

  /* Currency select menu */
  .currency-select {
    width: 100%;
    max-width: 250px;
    height: 38px;
    padding: 0 10px;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-base);
    outline: none;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .currency-select:focus {
    border-color: var(--color-primary);
  }

  /* Slider range */
  .slider-range {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    outline: none;
    margin: 6px 0;
    cursor: pointer;
  }

  .slider-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--color-bg-surface);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), background-color var(--transition-fast);
  }

  .slider-range::-webkit-slider-thumb:hover {
    transform: scale(1.1);
    background: var(--color-primary-hover);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .result-tile {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tile-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .tile-value {
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .net-value-container {
      flex-direction: column;
    }
  }

  @media (max-width: 420px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 500px) {
    .input-label-row {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-2);
    }

    .input-symbol-wrapper {
      width: 100% !important;
      max-width: 100% !important;
    }

    .currency-select {
      max-width: 100% !important;
    }
  }
</style>

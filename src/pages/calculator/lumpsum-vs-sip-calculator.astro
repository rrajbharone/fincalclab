---
import Layout from '../../layouts/Layout.astro';
import SipCalculator from '../../components/calculator/SipCalculator.astro';
import Accordion from '../../components/ui/Accordion.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';

// FAQ Content for Schema.org SEO and Page Accordions
const faqs = [
  {
    question: "What is the difference between a Lumpsum and a SIP investment?",
    answer: "A Lumpsum investment is a one-time single deposit of bulk capital into a mutual fund. A Systematic Investment Plan (SIP) is a method where you invest a fixed sum at regular intervals (typically monthly) to build wealth gradually and average market volatility."
  },
  {
    question: "Which strategy yields higher returns, Lumpsum or SIP?",
    answer: "Mathematically, in a consistently rising market, a lumpsum investment yields higher returns because the entire capital compounds from day one. However, in volatile or falling markets, a SIP is often superior due to Rupee Cost Averaging, which lowers the average acquisition cost of fund units."
  },
  {
    question: "What is Rupee Cost Averaging in SIPs?",
    answer: "Rupee Cost Averaging is the process where your fixed periodic SIP buys more mutual fund units when market prices (NAV) are low, and fewer units when prices are high. Over time, this averages your purchase price and insulates you from the risk of timing the market."
  },
  {
    question: "Does the calculator support compounding interest?",
    answer: "Yes. The lumpsum calculation compounds annually based on the expected return rate. The SIP calculation compounds monthly, matching the actual systematic deposit cycle of mutual funds. The formulas used are standard in professional investment planning."
  }
];
---

<Layout
  title="Lumpsum vs SIP Comparison Calculator"
  description="Compare the wealth generated by a one-time lumpsum investment versus a systematic monthly investment plan (SIP). Analyze projections with interactive SVG charts."
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Calculators', item: '/all-calculators' },
    { name: 'SIP vs Lumpsum', item: '/calculator/lumpsum-vs-sip-calculator' }
  ]}
  faqs={faqs}
>
  <!-- Render the interactive module -->
  <SipCalculator />

  <!-- Educational Explanations Slot projected down inside Extra Content section of page -->
  <div class="calculator-extra-seo-content container" style="max-width: 1040px; margin-top: var(--space-8);">
    <!-- Formula Section -->
    <section class="seo-section">
      <h2>How the Calculations Work (Formulas)</h2>
      <p>This calculator uses industry-standard financial formulas to project the compound growth of your assets under both strategies:</p>
      
      <div class="formula-box-grid">
        <Card elevation="sm" class="formula-card">
          <h3>Lumpsum Formula</h3>
          <p>Lumpsum growth compounds annually based on the compound interest formula:</p>
          <div class="math-expr">
            \[A = P \times (1 + r)^t\]
          </div>
          <ul class="formula-legend">
            <li><strong>A:</strong> Future Maturity Value</li>
            <li><strong>P:</strong> Principal Invested Amount</li>
            <li><strong>r:</strong> Expected Annual Return (%)</li>
            <li><strong>t:</strong> Time period (in Years)</li>
          </ul>
        </Card>

        <Card elevation="sm" class="formula-card">
          <h3>SIP Formula</h3>
          <p>SIP growth compounds monthly using the Future Value of an Annuity Due formula:</p>
          <div class="math-expr" set:html={`\\[M = P \\times \\frac{(1 + i)^n - 1}{i} \\times (1 + i)\\]`} />
          <ul class="formula-legend">
            <li><strong>M:</strong> Maturity Value</li>
            <li><strong>P:</strong> Monthly Investment Amount</li>
            <li><strong>i:</strong> Monthly interest rate (\(r / 12 / 100\))</li>
            <li><strong>n:</strong> Number of installments (\(years \times 12\))</li>
          </ul>
        </Card>
      </div>
    </section>

    <!-- How it works -->
    <section class="seo-section">
      <h2>SIP vs Lumpsum: Step-by-Step Investment Guide</h2>
      <p>Understanding which tool is right for you requires analyzing your cash flow and market outlook:</p>
      <ol class="spaced-list">
        <li>
          <strong>Assess Your Cash Flow:</strong> If you earn a regular salary with monthly surpluses, starting a monthly SIP is natural. If you have windfalls (bonuses, inheritance, tax refunds), lumpsum is suitable.
        </li>
        <li>
          <strong>Evaluate Market Timing:</strong> Investing a lumpsum requires caution. Buying at market peaks can lead to temporary losses. SIP removes this stress by investing through peaks and valleys.
        </li>
        <li>
          <strong>Compounding Horizon:</strong> The longer your money compounds, the more powerful the difference becomes. Run tests for 10, 20, and 30 years to see the curve step upward exponentially.
        </li>
      </ol>
    </section>

    <!-- FAQs Section -->
    <section class="seo-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-accordion-group">
        {faqs.map((faq) => (
          <Accordion title={faq.question}>
            <p style="margin:0;">{faq.answer}</p>
          </Accordion>
        ))}
      </div>
    </section>

    <!-- Call to action related tools -->
    <section class="related-tools-cta">
      <Card elevation="md" class="related-cta-card">
        <div class="cta-inner">
          <div class="cta-text-side">
            <h3>Try Our Other Free Calculators</h3>
            <p>Calculate pocket money compounds for children or estimate your take-home salary slabs instantly.</p>
          </div>
          <div class="cta-btn-side">
            <Button href="/calculator/kids-pocket-money-compounder-calculator" variant="primary">Kids Compounder</Button>
            <Button href="/calculator/in-hand-salary-calculator" variant="outline">Salary Slabs Tool</Button>
          </div>
        </div>
      </Card>
    </section>
  </div>
</Layout>

<style>
  .seo-section {
    margin-bottom: var(--space-12);
  }

  .seo-section h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
  }

  .spaced-list li {
    margin-bottom: var(--space-4);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .formula-box-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-top: var(--space-4);
  }

  .formula-card {
    padding: var(--space-6);
  }

  .formula-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .math-expr {
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    text-align: center;
    font-size: 1.2rem;
    font-weight: 600;
    margin: var(--space-4) 0;
    overflow-x: auto;
  }

  .formula-legend {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0 0;
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .formula-legend li {
    margin-bottom: 0;
  }

  /* FAQ Accordion list overrides */
  .faq-accordion-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* CTA related tools card */
  .related-tools-cta {
    margin-top: var(--space-12);
  }

  .related-cta-card {
    background-color: var(--color-bg-surface);
    border-top: 4px solid var(--color-accent);
  }

  .cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-6);
  }

  .cta-text-side h3 {
    margin: 0 0 6px 0;
  }
  .cta-text-side p {
    margin: 0;
    font-size: 0.95rem;
  }

  .cta-btn-side {
    display: flex;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .formula-box-grid {
      grid-template-columns: 1fr;
    }
    .cta-inner {
      flex-direction: column;
      text-align: center;
    }
    .cta-btn-side {
      flex-direction: column;
      width: 100%;
    }
    .cta-btn-side a, .cta-btn-side button {
      width: 100%;
    }
  }
</style>

<!-- Load LaTeX Math renderer via CDN dynamically in body if expression is present -->
<script is:inline src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

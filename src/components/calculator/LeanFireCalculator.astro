---
import CalculatorLayout from './CalculatorLayout.astro';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
---

<CalculatorLayout
  title="Lean FIRE Calculator"
  description="Calculate your minimalist early retirement nest egg. See how frugal living slashes your required retirement portfolio, comparison against Standard FIRE, and your exact years-to-freedom timeline."
  category="Savings"
>
  <!-- Inputs Section -->
  <div slot="inputs" class="calc-inputs-wrapper" id="lean-fire-calculator">
    
    <!-- Step 1: Currency & Minimalist Expenses -->
    <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-3);">1. Frugal Expenses & Withdrawal Rate</h3>
    
    <!-- Currency Selector -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="lf-currency-select">Currency</label>
        <select id="lf-currency-select" class="currency-select" aria-label="Select Currency">
          <option value="USD" selected>USD ($) - US Dollar</option>
          <option value="EUR">EUR (€) - Euro</option>
          <option value="GBP">GBP (£) - British Pound</option>
          <option value="INR">INR (₹) - Indian Rupee</option>
          <option value="JPY">JPY (¥) - Japanese Yen</option>
          <option value="AUD">AUD (A$) - Australian Dollar</option>
          <option value="CAD">CAD (C$) - Canadian Dollar</option>
          <option value="SGD">SGD (S$) - Singapore Dollar</option>
          <option value="CHF">CHF (CHF) - Swiss Franc</option>
        </select>
      </div>
    </div>

    <!-- Target Lean Annual Living Expenses -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="lf-lean-exp-input">Target Lean Annual Living Expenses</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="lf-lean-exp-input" min="10000" step="1000" value="30000" aria-label="Target Lean Annual Living Expenses" />
        </div>
      </div>
      <input type="range" id="lf-lean-exp-slider" min="15000" max="50000" step="1000" value="30000" class="slider-range" aria-label="Lean Expenses Slider" />
    </div>

    <!-- Standard (Non-Frugal) Annual Expenses -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="lf-std-exp-input">Standard Annual Expenses (For Comparison)</label>
        <div class="input-symbol-wrapper">
          <span class="currency-symbol">$</span>
          <input type="number" id="lf-std-exp-input" min="30000" step="2500" value="75000" aria-label="Standard Annual Expenses" />
        </div>
      </div>
      <input type="range" id="lf-std-exp-slider" min="40000" max="120000" step="2500" value="75000" class="slider-range" aria-label="Standard Expenses Slider" />
    </div>

    <!-- Safe Withdrawal Rate -->
    <div class="input-group">
      <div class="input-label-row">
        <label for="lf-swr-input">Safe Withdrawal Rate (SWR)</label>
        <div class="input-symbol-wrapper">
          <input type="number" id="lf-swr-input" min="2.0" max="6.0" step="0.25" value="4.0" aria-label="Safe Withdrawal Rate" style="text-align: left;" />
          <span class="percent-symbol">%</span>
        </div>
      </div>
      <input type="range" id="lf-swr-slider" min="2.5" max="5.0" step="0.25" value="4.0" class="slider-range" aria-label="SWR Slider" />
    </div>

    <!-- Step 2: Portfolio Accumulation & Growth -->
    <div style="margin-top: var(--space-5);">
      <h3 style="font-size: 1rem; font-weight: 700; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; margin-bottom: var(--space-4);">2. Current Portfolio & Savings Rate</h3>
      
      <!-- Current Invested Portfolio -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="lf-port-input">Current Invested Portfolio Balance</label>
          <div class="input-symbol-wrapper">
            <span class="currency-symbol">$</span>
            <input type="number" id="lf-port-input" min="0" step="5000" value="150000" aria-label="Current Invested Portfolio Balance" />
          </div>
        </div>
        <input type="range" id="lf-port-slider" min="0" max="800000" step="10000" value="150000" class="slider-range" aria-label="Current Portfolio Slider" />
      </div>

      <!-- Annual Contribution -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="lf-contrib-input">Annual Investment Contribution</label>
          <div class="input-symbol-wrapper">
            <span class="currency-symbol">$</span>
            <input type="number" id="lf-contrib-input" min="0" step="1000" value="25000" aria-label="Annual Investment Contribution" />
          </div>
        </div>
        <input type="range" id="lf-contrib-slider" min="0" max="80000" step="2500" value="25000" class="slider-range" aria-label="Annual Contribution Slider" />
      </div>

      <!-- Expected Return Rate -->
      <div class="input-group">
        <div class="input-label-row">
          <label for="lf-return-input">Expected Investment Return Rate</label>
          <div class="input-symbol-wrapper">
            <input type="number" id="lf-return-input" min="2.0" max="15.0" step="0.5" value="7.0" aria-label="Expected Investment Return Rate" style="text-align: left;" />
            <span class="percent-symbol">%</span>
          </div>
        </div>
        <input type="range" id="lf-return-slider" min="3.0" max="12.0" step="0.5" value="7.0" class="slider-range" aria-label="Return Rate Slider" />
      </div>
    </div>

    <!-- Reset Trigger -->
    <div class="inputs-actions" style="margin-top: var(--space-6);">
      <Button id="lf-reset" variant="outline" size="sm" style="width: 100%;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
        Reset Calculator Inputs
      </Button>
    </div>
  </div>

  <!-- Results Section -->
  <div slot="results" class="calc-results-wrapper">
    <h3 class="results-heading">Lean FIRE Targets & Timeline</h3>

    <!-- Core Payout Displays -->
    <div class="net-value-container" style="display: flex; gap: var(--space-4); margin-bottom: var(--space-5);">
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-success);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Lean FIRE Target Nest Egg</span>
        <div id="res-lf-target" style="font-size: 1.75rem; font-weight: 800; color: var(--color-success); margin-top: 4px;">$750,000.00</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-lf-std-target">Standard Target: $1,875,000.00</span>
      </div>
      <div class="net-value-box" style="flex: 1; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4); background: var(--color-bg-base); border-top: 4px solid var(--color-primary);">
        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-light);">Time to Lean FIRE</span>
        <div id="res-lf-years" style="font-size: 1.75rem; font-weight: 800; color: var(--color-primary); margin-top: 4px;">11.6 years</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-lf-years-saved">Saves 9.1 years vs Standard FIRE</span>
      </div>
    </div>

    <!-- Optimization Verdict -->
    <div style="margin-bottom: var(--space-6);">
      <Card elevation="sm" id="lf-verdict-card" style="border-left: 4px solid var(--color-success); padding: var(--space-4) var(--space-5); background: var(--color-bg-base);">
        <span style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--color-text-muted);">Minimalist Early Retirement Shortcut</span>
        <p id="res-lf-verdict-text" style="margin: 4px 0 0 0; font-size: 0.875rem; line-height: 1.5; color: var(--color-text-muted);">
          A lean budget of <strong>$30,000/yr</strong> ($2,500/mo) slashes your required nest egg by <strong>$1,125,000</strong> (a 60% discount).
        </p>
      </Card>
    </div>

    <!-- Key Metrics Grid -->
    <h4 style="font-size: 0.95rem; font-weight: 700; margin-bottom: var(--space-3);">Frugal FIRE Economics Breakdown</h4>
    <div class="results-grid lf-metrics-grid">
      <div class="result-tile">
        <span class="tile-label">Monthly Lean Budget</span>
        <div class="tile-value" id="tile-lf-monthly-budget" style="color: var(--color-primary);">$2,500/mo</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-lf-budget-desc">$30,000 annual spending</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Capital Saved</span>
        <div class="tile-value" id="tile-lf-cap-saved" style="color: var(--color-accent);">$1,125,000</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);" id="lbl-lf-disc-pct">60.0% nest egg discount</span>
      </div>

      <div class="result-tile">
        <span class="tile-label">Standard FIRE Timeline</span>
        <div class="tile-value" id="tile-lf-std-years" style="color: var(--color-text-base);">20.7 yrs</div>
        <span style="font-size: 0.65rem; color: var(--color-text-light);">To reach 100% full standard FIRE</span>
      </div>
    </div>
  </div>
</CalculatorLayout>

<script>
  function initLfCalculator() {
    // Select elements
    const currencySelect = document.getElementById('lf-currency-select') as HTMLSelectElement;

    const leanExpInput = document.getElementById('lf-lean-exp-input') as HTMLInputElement;
    const leanExpSlider = document.getElementById('lf-lean-exp-slider') as HTMLInputElement;
    const stdExpInput = document.getElementById('lf-std-exp-input') as HTMLInputElement;
    const stdExpSlider = document.getElementById('lf-std-exp-slider') as HTMLInputElement;
    const swrInput = document.getElementById('lf-swr-input') as HTMLInputElement;
    const swrSlider = document.getElementById('lf-swr-slider') as HTMLInputElement;

    const portInput = document.getElementById('lf-port-input') as HTMLInputElement;
    const portSlider = document.getElementById('lf-port-slider') as HTMLInputElement;
    const contribInput = document.getElementById('lf-contrib-input') as HTMLInputElement;
    const contribSlider = document.getElementById('lf-contrib-slider') as HTMLInputElement;
    const returnInput = document.getElementById('lf-return-input') as HTMLInputElement;
    const returnSlider = document.getElementById('lf-return-slider') as HTMLInputElement;

    if (!leanExpInput || !currencySelect || !stdExpInput || !portInput) return;

    // Slider bindings
    function bindSlider(input: HTMLInputElement, slider: HTMLInputElement) {
      if (!input || !slider) return;
      input.addEventListener('input', () => {
        slider.value = input.value;
        calculateAll();
      });
      slider.addEventListener('input', () => {
        input.value = slider.value;
        calculateAll();
      });
    }

    bindSlider(leanExpInput, leanExpSlider);
    bindSlider(stdExpInput, stdExpSlider);
    bindSlider(swrInput, swrSlider);
    bindSlider(portInput, portSlider);
    bindSlider(contribInput, contribSlider);
    bindSlider(returnInput, returnSlider);

    // Currency updates
    currencySelect.addEventListener('change', () => {
      const symbol = getCurrencySymbol(currencySelect.value);
      document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = symbol);
      calculateAll();
    });

    function getCurrencySymbol(curr: string) {
      switch (curr) {
        case 'EUR': return '€';
        case 'GBP': return '£';
        case 'INR': return '₹';
        case 'JPY': return '¥';
        case 'AUD': return 'A$';
        case 'CAD': return 'C$';
        case 'SGD': return 'S$';
        case 'CHF': return 'CHF';
        default: return '$';
      }
    }

    // Reset button
    const resetBtn = document.getElementById('lf-reset');
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        leanExpInput.value = '30000';
        leanExpSlider.value = '30000';
        stdExpInput.value = '75000';
        stdExpSlider.value = '75000';
        swrInput.value = '4.0';
        swrSlider.value = '4.0';

        portInput.value = '150000';
        portSlider.value = '150000';
        contribInput.value = '25000';
        contribSlider.value = '25000';
        returnInput.value = '7.0';
        returnSlider.value = '7.0';
        currencySelect.value = 'USD';

        document.querySelectorAll('.currency-symbol').forEach(el => el.textContent = '$');
        calculateAll();
      });
    }

    function formatCurrency(val: number) {
      const symbol = getCurrencySymbol(currencySelect.value);
      return symbol + val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    // Solve compounding years
    function calculateYearsToTarget(startPort: number, annualContrib: number, rate: number, target: number): number {
      if (startPort >= target) return 0;
      let current = startPort;
      let years = 0;
      const r = rate / 100;
      
      // Safety cap at 100 years
      while (current < target && years < 100) {
        current = current * (1 + r) + annualContrib;
        years++;
      }
      return years;
    }

    function calculateAll() {
      // Inputs variables
      const leanExp = parseFloat(leanExpInput.value) || 0;
      const stdExp = parseFloat(stdExpInput.value) || 0;
      const swrPct = parseFloat(swrInput.value) || 4.0;

      const currentPort = parseFloat(portInput.value) || 0;
      const annualContrib = parseFloat(contribInput.value) || 0;
      const returnRate = parseFloat(returnInput.value) || 7.0;

      // Lean vs Standard Targets
      const monthlyLean = leanExp / 12;
      const leanTarget = swrPct > 0 ? leanExp / (swrPct / 100) : 0;
      const stdTarget = swrPct > 0 ? stdExp / (swrPct / 100) : 0;

      const capitalSaved = Math.max(0, stdTarget - leanTarget);
      const discountPct = stdExp > 0 ? ((stdExp - leanExp) / stdExp) * 100 : 0;

      // Timelines
      const yearsLean = calculateYearsToTarget(currentPort, annualContrib, returnRate, leanTarget);
      const yearsStd = calculateYearsToTarget(currentPort, annualContrib, returnRate, stdTarget);
      const yearsSaved = Math.max(0, yearsStd - yearsLean);

      // DOM Updates
      const resTarget = document.getElementById('res-lf-target');
      const resYears = document.getElementById('res-lf-years');
      const lblStdTarget = document.getElementById('lbl-lf-std-target');
      const lblYearsSaved = document.getElementById('lbl-lf-years-saved');

      if (resTarget) resTarget.textContent = formatCurrency(leanTarget);
      if (resYears) resYears.textContent = yearsLean.toFixed(1) + ' years';
      if (lblStdTarget) lblStdTarget.textContent = `Standard Target: ${formatCurrency(stdTarget)}`;
      if (lblYearsSaved) lblYearsSaved.textContent = `Saves ${yearsSaved.toFixed(1)} years vs Standard FIRE`;

      // Verdict card and text
      const verdictText = document.getElementById('res-lf-verdict-text');
      if (verdictText) {
        verdictText.innerHTML = `Living on a minimalist budget of <strong>${formatCurrency(leanExp)}/yr</strong> (<strong>${formatCurrency(monthlyLean)}/mo</strong>) slashes your required retirement nest egg from <strong>${formatCurrency(stdTarget)}</strong> down to <strong>${formatCurrency(leanTarget)}</strong> (saving <strong>${formatCurrency(capitalSaved)}</strong>, a <strong>${discountPct.toFixed(1)}% discount</strong>). You reach full financial independence <strong>${yearsSaved.toFixed(1)} years sooner</strong> (in <strong>${yearsLean.toFixed(1)} years</strong> instead of <strong>${yearsStd.toFixed(1)} years</strong>).`;
      }

      // Details Tiles Updates
      const tileMonthlyBudget = document.getElementById('tile-lf-monthly-budget');
      const lblBudgetDesc = document.getElementById('lbl-lf-budget-desc');
      const tileCapSaved = document.getElementById('tile-lf-cap-saved');
      const lblDiscPct = document.getElementById('lbl-lf-disc-pct');
      const tileStdYears = document.getElementById('tile-lf-std-years');

      const symbol = getCurrencySymbol(currencySelect.value);
      if (tileMonthlyBudget) tileMonthlyBudget.textContent = formatCurrency(monthlyLean).split('.')[0] + '/mo';
      if (lblBudgetDesc) lblBudgetDesc.textContent = `${formatCurrency(leanExp)} annual spending`;

      if (tileCapSaved) tileCapSaved.textContent = formatCurrency(capitalSaved).split('.')[0];
      if (lblDiscPct) lblDiscPct.textContent = `${discountPct.toFixed(1)}% nest egg discount`;

      if (tileStdYears) tileStdYears.textContent = yearsStd.toFixed(1) + ' yrs';
    }

    // Trigger initial calculation
    calculateAll();

    // Clipboard copy results handler
    window.addEventListener('copy-calculator-results', () => {
      const text = `Lean FIRE Minimalist Early Retirement Analysis:\n` +
                   `Target Lean Expenses: ${leanExpInput.value}/yr (${document.getElementById('tile-lf-monthly-budget')?.textContent})\n` +
                   `Standard Expenses: ${stdExpInput.value}/yr | SWR: ${swrInput.value}%\n` +
                   `Lean FIRE Target: ${document.getElementById('res-lf-target')?.textContent} (${document.getElementById('lbl-lf-std-target')?.textContent})\n` +
                   `Capital Saved: ${document.getElementById('tile-lf-cap-saved')?.textContent} (${document.getElementById('lbl-lf-disc-pct')?.textContent})\n` +
                   `Current Portfolio: ${portInput.value} | Annual Contribution: ${contribInput.value} @ ${returnInput.value}%\n` +
                   `Timeline: ${document.getElementById('res-lf-years')?.textContent} to Lean FIRE (${document.getElementById('lbl-lf-years-saved')?.textContent})\n` +
                   `Diagnosis: ${document.getElementById('res-lf-verdict-text')?.textContent}`;
      
      navigator.clipboard.writeText(text).then(() => {
        window.dispatchEvent(new CustomEvent('calculator-copied-success'));
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initLfCalculator);
  document.addEventListener('astro:after-swap', initLfCalculator);
</script>

<style>
  .calc-inputs-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .input-label-row label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-base);
  }

  /* Input symbol wrapper */
  .input-symbol-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0 10px;
    width: 145px;
    height: 38px;
    transition: border-color var(--transition-fast);
  }

  .input-symbol-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .currency-symbol {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-right: 4px;
  }

  .input-symbol-wrapper input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-base);
    text-align: right;
    outline: none;
  }

  .input-symbol-wrapper input::-webkit-outer-spin-button,
  .input-symbol-wrapper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .percent-symbol {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-light);
    margin-left: 4px;
    white-space: nowrap;
  }

  /* Currency select menu */
  .currency-select {
    width: 100%;
    max-width: 250px;
    height: 38px;
    padding: 0 10px;
    background-color: var(--color-bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-base);
    outline: none;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .currency-select:focus {
    border-color: var(--color-primary);
  }

  /* Slider range */
  .slider-range {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
    outline: none;
    margin: 6px 0;
    cursor: pointer;
  }

  .slider-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--color-bg-surface);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), background-color var(--transition-fast);
  }

  .slider-range::-webkit-slider-thumb:hover {
    transform: scale(1.1);
    background: var(--color-primary-hover);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .result-tile {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tile-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-light);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .tile-value {
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .net-value-container {
      flex-direction: column;
    }
  }

  @media (max-width: 420px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 500px) {
    .input-label-row {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-2);
    }

    .input-symbol-wrapper {
      width: 100% !important;
      max-width: 100% !important;
    }

    .currency-select {
      max-width: 100% !important;
    }
  }
</style>
